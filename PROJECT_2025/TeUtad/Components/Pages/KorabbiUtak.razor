    private IEnumerable<Trip> FilteredTrips
    {
        get
        {
            return selectedFilter switch
            {
                "upcoming" => allTrips.Where(t => t.Status == "upcoming"),
                "completed" => allTrips.Where(t => t.Status == "completed"),
                "favorites" => allTrips.Where(t => t.IsFavorite),
                _ => allTrips
            };
        }
    }

    private void ToggleFavorite(int tripId)
    {
        var trip = allTrips.FirstOrDefault(t => t.Id == tripId);
        if (trip != null)
        {
            trip.IsFavorite = !trip.IsFavorite;
            StateHasChanged();
        }
    }

    private void ViewTripDetails(int tripId)
    {
        NavigationManager.NavigateTo($"/ut-tervezes?tripId={tripId}");
    }
