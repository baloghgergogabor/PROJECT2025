@page "/bejelentkezes"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Components.Web
@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Security.Cryptography
@using System.Security.Claims
@using TeUtad.LIB.Modul
@using TeUtad.SERVICE
@inject FelhasznaloSzerviz Felhasznalo
@inject SzerepSzerviz Szerep
@inject NavigationManager nav
@inject IJSRuntime jsRun
<PageTitle>Bejelentkezés — TeUtad</PageTitle>

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet"/>

</head>
<div class="min-vh-100 d-flex align-items-center py-5">
    <div class="container">
        <!-- Brand -->
        <div class="text-center mb-4">
            <a href="/" class="brand-link">
                <h1 class="fw-bold fs-2">
                    <i class="bi bi-compass me-2"></i>TeUtad
                </h1>
            </a>
        </div>

        <!-- Login Card -->
        <div class="login-card">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-4 p-md-5">
                    <h2 class="fw-bold mb-2">Jó újra látni!</h2>
                    <p class="text-muted mb-4">Jelentkezz be a fiókodba</p>

                    <EditForm Model="@loginModel" OnValidSubmit="@HandleLogin">
                        <DataAnnotationsValidator />

                        <!-- FelhasznaloNev -->
                        <div class="mb-3">
                            <label for="Nev" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white">
                                    <i class="bi bi-envelope text-muted"></i>
                                </span>
                                <InputText @bind-Value="loginModel.FelhasznaloNev" 
                                class="form-control" 
                                id="Nev" 
                                placeholder="Kovácskata" />
                            </div>
                            <ValidationMessage For="@(() => loginModel.FelhasznaloNev)" class="text-danger small" />
                        </div>

                        <!-- Password -->
                        <div class="mb-3">
                            <label for="password" class="form-label fw-semibold">Jelszó</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white">
                                    <i class="bi bi-lock text-muted"></i>
                                </span>
                                <InputText @bind-Value="loginModel.Password" 
                                type="@(showPassword ? "text" : "password")" 
                                class="form-control" 
                                id="password" 
                                placeholder="Jelszavad" />
                                <button class="btn btn-outline-secondary" 
                                type="button" 
                                @onclick="TogglePasswordVisibility">
                                    <i class="bi bi-eye@(showPassword ? "-slash" : "")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => loginModel.Password)" class="text-danger small" />
                        </div>



                        <!-- Login Button -->
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold rounded-pill mb-3">
                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            Bejelentkezés
                        </button>

                        <!-- Divider -->
                        <div class="position-relative my-4">
                            <hr class="text-muted">
                            <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted small">
                                vagy
                            </span>
                        </div>

                    </EditForm>

                    <!-- Register Link -->
                    <div class="text-center mt-4">
                        <p class="text-muted small mb-0">
                            Még nincs fiókod? 
                            <a href="/regisztracio" class="text-primary text-decoration-none fw-semibold">
                                Regisztrálj most
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

@code {
    List<FelhasznaloAdat> Felhasznalok = [];
    protected override async Task OnInitializedAsync()
    {
        try
        {
            Felhasznalok = await Felhasznalo.GetAllFelhasznalo();
        }
        catch(Exception error)
        {
            Console.WriteLine($"Error: {error}");
        }
    }
    private LoginModel loginModel = new LoginModel();
    private bool showPassword = false;

    public class LoginModel
    {
        [Required(ErrorMessage = "A felhasznaló név megadása kötelező")]
        public string FelhasznaloNev { get; set; } = string.Empty;

        [Required(ErrorMessage = "A jelszó megadása kötelező")]
        [MinLength(6, ErrorMessage = "A jelszónak legalább 6 karakter hosszúnak kell lennie")]
        public string Password { get; set; } = string.Empty;

    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private async Task HandleLogin()
    {
        // Bejelentkezési logika ide
        // Például API hívás, token mentés stb.
        var Sha = new SHA256Managed();
        // Bejelentkezési logika ide
        var FelahasznaloProbalkozas = Felhasznalok.Where(x => x.FelhasznaloNev == loginModel.FelhasznaloNev).FirstOrDefault();
        if (FelahasznaloProbalkozas is null || FelahasznaloProbalkozas.JelszoHash != Convert.ToBase64String(Sha.ComputeHash(Encoding.UTF8.GetBytes(loginModel.Password))))
        {
            await jsRun.InvokeVoidAsync("alert", "Nem megfelelő E-mail cím vagy jelszó!");
            return;
        }
        Szerep Szerpe = await Szerep.GetByIdSzerep(FelahasznaloProbalkozas.SzerepId);
        var claims = new List<Claim>
            {
                new Claim(ClaimTypes.Name, loginModel.FelhasznaloNev),
                new Claim(ClaimTypes.Role, Szerpe.Szerepe)
            };
        var idententity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
        var principal = new ClaimsPrincipal(idententity);
        await HttpContext.SignInAsync(principal);
        nav.NavigateTo("/");
    }
}
