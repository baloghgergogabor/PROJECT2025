@page "/regisztracio"
@using Microsoft.AspNetCore.Components.Web
@using System.ComponentModel.DataAnnotations

<PageTitle>Regisztráció — TeUtad</PageTitle>

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet"/>
</head>

<style>
    body { 
        font-family: 'Nunito', sans-serif; 
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        min-height: 100vh;
    }
    
    .register-card {
        max-width: 540px;
        margin: 0 auto;
    }
    
    .brand-link {
        text-decoration: none;
        color: white;
        transition: opacity 0.2s;
    }
    
    .brand-link:hover {
        opacity: 0.8;
        color: white;
    }

    .password-strength {
        height: 4px;
        background: #e9ecef;
        border-radius: 2px;
        overflow: hidden;
    }

    .password-strength-bar {
        height: 100%;
        transition: all 0.3s;
    }
</style>

<div class="min-vh-100 d-flex align-items-center py-5">
    <div class="container">
        <!-- Brand -->
        <div class="text-center mb-4">
            <a href="/" class="brand-link">
                <h1 class="fw-bold fs-2">
                    <i class="bi bi-compass me-2"></i>TeUtad
                </h1>
            </a>
        </div>

        <!-- Register Card -->
        <div class="register-card">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-4 p-md-5">
                    <h2 class="fw-bold mb-2">Új fiók létrehozása</h2>
                    <p class="text-muted mb-4">Kezdd el a tervezést még ma</p>

                    <EditForm Model="@registerModel" OnValidSubmit="@HandleRegister">
                        <DataAnnotationsValidator />

                        <!-- Name -->
                        <div class="mb-3">
                            <label for="name" class="form-label fw-semibold">Teljes név</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white">
                                    <i class="bi bi-person text-muted"></i>
                                </span>
                                <InputText @bind-Value="registerModel.FullName" 
                                          class="form-control" 
                                          id="name" 
                                          placeholder="Kovács János" />
                            </div>
                            <ValidationMessage For="@(() => registerModel.FullName)" class="text-danger small" />
                        </div>

                        <!-- Email -->
                        <div class="mb-3">
                            <label for="email" class="form-label fw-semibold">E-mail cím</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white">
                                    <i class="bi bi-envelope text-muted"></i>
                                </span>
                                <InputText @bind-Value="registerModel.Email" 
                                          type="email" 
                                          class="form-control" 
                                          id="email" 
                                          placeholder="pelda@email.com" />
                            </div>
                            <ValidationMessage For="@(() => registerModel.Email)" class="text-danger small" />
                        </div>

                        <!-- Password -->
                        <div class="mb-3">
                            <label for="password" class="form-label fw-semibold">Jelszó</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white">
                                    <i class="bi bi-lock text-muted"></i>
                                </span>
                                <InputText @bind-Value="registerModel.Password" 
                                          type="@(showPassword ? "text" : "password")" 
                                          class="form-control" 
                                          id="password" 
                                          placeholder="Legalább 8 karakter"
                                          @oninput="@((e) => CheckPasswordStrength(e.Value?.ToString()))" />
                                <button class="btn btn-outline-secondary" 
                                        type="button" 
                                        @onclick="TogglePasswordVisibility">
                                    <i class="bi bi-eye@(showPassword ? "-slash" : "")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => registerModel.Password)" class="text-danger small" />
                            
                            <!-- Password Strength Indicator -->
                            @if (!string.IsNullOrEmpty(registerModel.Password))
                            {
                                <div class="password-strength mt-2">
                                    <div class="password-strength-bar bg-@GetPasswordStrengthColor()" 
                                         style="width: @(passwordStrength * 33.33)%"></div>
                                </div>
                                <small class="text-@GetPasswordStrengthColor()">
                                    @GetPasswordStrengthText()
                                </small>
                            }
                        </div>

                        <!-- Confirm Password -->
                        <div class="mb-3">
                            <label for="confirmPassword" class="form-label fw-semibold">Jelszó megerősítése</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white">
                                    <i class="bi bi-lock-fill text-muted"></i>
                                </span>
                                <InputText @bind-Value="registerModel.ConfirmPassword" 
                                          type="@(showConfirmPassword ? "text" : "password")" 
                                          class="form-control" 
                                          id="confirmPassword" 
                                          placeholder="Jelszó újra" />
                                <button class="btn btn-outline-secondary" 
                                        type="button" 
                                        @onclick="ToggleConfirmPasswordVisibility">
                                    <i class="bi bi-eye@(showConfirmPassword ? "-slash" : "")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => registerModel.ConfirmPassword)" class="text-danger small" />
                        </div>

                        <!-- Terms & Conditions -->
                        <div class="mb-4">
                            <div class="form-check">
                                <InputCheckbox @bind-Value="registerModel.AcceptTerms" 
                                             class="form-check-input" 
                                             id="terms" />
                                <label class="form-check-label small" for="terms">
                                    Elfogadom az 
                                    <a href="/felhasznalasi-feltetelek" class="text-primary">Általános Szerződési Feltételeket</a> 
                                    és az 
                                    <a href="/adatvedelmi-iranyelvek" class="text-primary">Adatvédelmi Irányelveket</a>
                                </label>
                            </div>
                            <ValidationMessage For="@(() => registerModel.AcceptTerms)" class="text-danger small" />
                        </div>

                        <!-- Register Button -->
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold rounded-pill mb-3">
                            <i class="bi bi-person-plus me-2"></i>
                            Fiók létrehozása
                        </button>

                        <!-- Divider -->
                        <div class="position-relative my-4">
                            <hr class="text-muted">
                            <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted small">
                                vagy
                            </span>
                        </div>

                        <!-- Social Register -->
                        <button type="button" class="btn btn-outline-secondary w-100 py-2 mb-2 rounded-pill">
                            <i class="bi bi-google me-2"></i>
                            Regisztráció Google-lel
                        </button>
                        <button type="button" class="btn btn-outline-secondary w-100 py-2 rounded-pill">
                            <i class="bi bi-facebook me-2"></i>
                            Regisztráció Facebook-kal
                        </button>
                    </EditForm>

                    <!-- Login Link -->
                    <div class="text-center mt-4">
                        <p class="text-muted small mb-0">
                            Van már fiókod? 
                            <a href="/bejelentkezes" class="text-primary text-decoration-none fw-semibold">
                                Jelentkezz be
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

@code {
    private RegisterModel registerModel = new RegisterModel();
    private bool showPassword = false;
    private bool showConfirmPassword = false;
    private int passwordStrength = 0;

    public class RegisterModel
    {
        [Required(ErrorMessage = "A név megadása kötelező")]
        [MinLength(3, ErrorMessage = "A névnek legalább 3 karakter hosszúnak kell lennie")]
        public string FullName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Az e-mail cím megadása kötelező")]
        [EmailAddress(ErrorMessage = "Érvényes e-mail címet adj meg")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "A jelszó megadása kötelező")]
        [MinLength(8, ErrorMessage = "A jelszónak legalább 8 karakter hosszúnak kell lennie")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "A jelszó megerősítése kötelező")]
        [Compare(nameof(Password), ErrorMessage = "A jelszavak nem egyeznek")]
        public string ConfirmPassword { get; set; } = string.Empty;

        [Range(typeof(bool), "true", "true", ErrorMessage = "El kell fogadnod a feltételeket")]
        public bool AcceptTerms { get; set; } = false;
    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        showConfirmPassword = !showConfirmPassword;
    }

    private void CheckPasswordStrength(string password)
    {
        if (string.IsNullOrEmpty(password))
        {
            passwordStrength = 0;
            return;
        }

        int strength = 0;
        
        // Hossz
        if (password.Length >= 8) strength++;
        
        // Tartalmaz számot
        if (password.Any(char.IsDigit)) strength++;
        
        // Tartalmaz kis- és nagybetűt
        if (password.Any(char.IsLower) && password.Any(char.IsUpper)) strength++;
        
        // Tartalmaz speciális karaktert
        if (password.Any(c => !char.IsLetterOrDigit(c))) strength++;

        passwordStrength = Math.Min(strength, 3);
    }

    private string GetPasswordStrengthColor()
    {
        return passwordStrength switch
        {
            1 => "danger",
            2 => "warning",
            3 => "success",
            _ => "secondary"
        };
    }

    private string GetPasswordStrengthText()
    {
        return passwordStrength switch
        {
            1 => "Gyenge jelszó",
            2 => "Közepes jelszó",
            3 => "Erős jelszó",
            _ => ""
        };
    }

    private async Task HandleRegister()
    {
        // Regisztrációs logika ide
        // Például API hívás, token mentés, átirányítás stb.
        Console.WriteLine($"Regisztráció: {registerModel.FullName} ({registerModel.Email})");
    }
}
