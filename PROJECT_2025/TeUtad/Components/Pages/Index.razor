@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web


<PageTitle>TeUtad — YourWay</PageTitle>

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
</head>




<section class="hero-section d-flex align-items-center text-white">
    <div class="container text-center py-5">
        <span class="badge bg-white text-primary fw-semibold mb-3 px-3 py-2 fs-6">
            Utazz aggodalom nélkül TeUtad-on
        </span>

        <h1 class="display-4 fw-bold mb-3">
            Hová szeretnél menni?
            
        </h1>

        <div class="d-flex align-items-center gap-2 w-75 mx-auto">

            <input class="form-control" type="text" placeholder="Indulási hely (opcionális)" @bind="honnan">

            <button type="button" class="btn btn-info" @onclick="uticelcsere">
                <i class="bi bi-arrow-left-right"></i>
            </button>

            <input class="form-control" type="text" placeholder="Úticél" @bind="hova">

        </div>


        <p class="lead mb-5 opacity-75 mx-auto" style="max-width:520px">
            Tervezz személyre szabott utakat percek alatt. A TeUtad elkészíti a tökéletes útvonalat — a te ízlésed szerint.
        </p>


        <a href="/ut-tervezes" class="btn btn-warning btn-lg rounded-pill px-5 py-3 fw-bold shadow fs-5">
            <i class="bi bi-plus-circle me-2"></i>
            Út tervezésének indítása
        </a>

    </div>
</section>

<!-- TRIP CARDS -->
<main class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Népszerű úticélok</h2>
            <p class="text-muted mb-0">Ezreket inspirált már a TeUtad</p>
        </div>
        <a href="#" class="btn btn-outline-primary rounded-pill d-none d-md-inline-flex">
            Összes megtekintése <i class="bi bi-arrow-right ms-1"></i>
        </a>
    </div>

    <div class="row g-4">
        @foreach (var destination in destinations)
        {
            <div class="col-sm-6 col-lg-4">
                <div class="card trip-card border-0 shadow-sm rounded-4 overflow-hidden h-100"
                     @onmouseover="@(() => HandleCardHover(destination.Id, true))"
                     @onmouseout="@(() => HandleCardHover(destination.Id, false))">
                    <div class="destination-img bg-@destination.BadgeColor bg-gradient">@destination.Emoji</div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold mb-0">@destination.Name</h5>
                            <span class="badge bg-@destination.BadgeColor-subtle text-@destination.BadgeColor rounded-pill">
                                @GetBadgeText(destination.BadgeKey)
                            </span>
                        </div>
                        <p class="text-muted small mb-3">
                            <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                            @GetLocationText(destination.LocationKey)
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        <a href="#" class="btn btn-outline-primary btn-sm rounded-pill w-100">
                            Ezt tervezem
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="text-center mt-4 d-md-none">
        <a href="#" class="btn btn-outline-primary rounded-pill px-4">
            Összes megtekintése <i class="bi bi-arrow-right ms-1"></i>
        </a>
    </div>

    <div class="card border-0 bg-primary text-white rounded-4 shadow mt-5">
        <div class="card-body text-center py-5">

            <h4 class="fw-bold mb-2">Álmodd meg a saját utazásod!</h4>
            <p class="opacity-75">Nem tetszik ezek közül egyik sem?</p>
            <p class="opacity-75"> Tekintsd meg az összes úticélunkat vagy ha kalandvágyó vagy kezdd el tervezni a saját utazásod!</p>
            <a href="/ut-tervezes" class="btn btn-warning btn-lg rounded-pill px-5 fw-bold shadow-sm">
                <i class="bi bi-plus-circle me-2"></i>
                Út tervezésének indítása
            </a>
        </div>
    </div>
</main>

<!-- FOOTER -->
<footer class="bg-white border-top mt-4 py-4">
    <div class="container">
        <div class="row align-items-center gy-3">
            <div class="col-md-4 text-center text-md-start">
                <span class="fw-bold fs-5">
                    <i class="bi bi-compass text-primary me-1"></i>Te<span class="text-primary">Utad</span>
                </span>
                <span class="text-muted small ms-2">— YourWay</span>
            </div>
            <div class="col-md-4 text-center">
                <a href="#" class="text-muted text-decoration-none small me-3">Rólunk</a>
                <a href="#" class="text-muted text-decoration-none small me-3">Adatvédelem</a>
                <a href="#" class="text-muted text-decoration-none small me-3">Feltételek</a>
                <a href="#" class="text-muted text-decoration-none small">Kapcsolat</a>
            </div>
            <div class="col-md-4 text-center text-md-end">
                <a href="#" class="text-muted me-3"><i class="bi bi-instagram fs-5"></i></a>
                <a href="#" class="text-muted me-3"><i class="bi bi-twitter-x fs-5"></i></a>
                <a href="#" class="text-muted"><i class="bi bi-facebook fs-5"></i></a>
            </div>
        </div>
        <div class="text-center text-muted small mt-3">
            © 2025 TeUtad. Minden jog fenntartva.
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

@code {

    string debug = "";
    string honnan = "";
    string hova = "";

    void uticelcsere()
    {
        var temp = honnan;
        honnan = hova;
        hova = temp;
        debug = "csere";
        StateHasChanged();
    }



    private class Destination
    {
        public int Id { get; set; }
        public string Name { get; set; }
        public string Emoji { get; set; }
        public string BadgeKey { get; set; }
        public string BadgeColor { get; set; }
        public string LocationKey { get; set; }

    }

    private List<Destination> destinations = new List<Destination>
    {
        new Destination { Id = 1, Name = "Paris, Franciaország", Emoji = "🗼", BadgeKey = "badge_trending", BadgeColor = "primary", LocationKey = "loc_paris"}
    };

    private Dictionary<string, string> badges = new Dictionary<string, string>
    {
        ["badge_trending"] = "Trending",
        ["badge_deal"] = "Akció",
        ["badge_bestseller"] = "Legnépszerűbb",
        ["badge_eco"] = "Öko ajánlat",
        ["badge_new"] = "Új",
        ["badge_adventure"] = "Kaland"
    };

    private Dictionary<string, string> locations = new Dictionary<string, string>
    {
        ["loc_paris"] = "Nyugat-Európa · 5–10 nap",
        ["loc_marrakech"] = "Észak-Afrika · 4–7 nap",
        ["loc_kyoto"] = "Kelet-Ázsia · 7–14 nap",
        ["loc_costarica"] = "Közép-Amerika · 6–10 nap",
        ["loc_santorini"] = "Mediterrán · 5–8 nap",
        ["loc_serengeti"] = "Kelet-Afrika · 8–14 nap"
    };

    private string GetBadgeText(string key)
    {
        return badges.ContainsKey(key) ? badges[key] : key;
    }

    private string GetLocationText(string key)
    {
        return locations.ContainsKey(key) ? locations[key] : key;
    }

    private void HandleCardHover(int destinationId, bool isHovering)
    {
        // Opcionális: hover logika, pl. analytics tracking
    }
}
