@page "/"
@rendermode InteractiveServer
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using System.Web
@inject IJSRuntime JSRuntime


<PageTitle>TeUtad — YourWay</PageTitle>

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />

    <script src="/js/googleMaps.js"></script>

    <!-- Google Maps API -->
    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyBL9wuHLIfIK1LLTkqPA6sW4ltfXl2rbfo&libraries=places&callback=Function.prototype" async defer></script>
</head>




<section class="hero-section d-flex align-items-center text-white">
    <div class="container text-center py-5">
        <span class="badge bg-white text-primary fw-semibold mb-3 px-3 py-2 fs-6">
            Utazz aggodalom nélkül a TeUtad-on
        </span>

        <h1 class="display-4 fw-bold mb-4">
            Hova szeretne menni?
        </h1>

        @* Úticél és dátum keresés - Mobilbarát *@
        <div class="row g-3 w-100 w-md-75 mx-auto mb-4">
            @* Indulási hely - Opcionális (csak repjegy esetén) *@
            <div class="col-12 col-md-5">
                <input id="index-from-input"
                       class="form-control form-control-lg"
                       type="text"
                       placeholder="Indulási hely"
                       @bind="honnan"
                       @bind:event="oninput">
            </div>

            @* Csere gomb *@
            <div class="col-12 col-md-2 d-flex justify-content-center">
                <button type="button"
                        class="btn btn-info btn-lg rounded-circle"
                        @onclick="uticelcsere"
                        style="width: 50px; height: 50px;">
                    <i class="bi bi-arrow-left-right"></i>
                </button>
            </div>

            @* Úticél - Kötelező *@
            <div class="col-12 col-md-5">
                <input id="index-destination-input"
                       class="form-control form-control-lg @(string.IsNullOrWhiteSpace(hova) ? "border-warning" : "")"
                       type="text"
                       placeholder="Úticél (kötelező)"
                       @bind="hova"
                       @bind:event="oninput">
                @if (string.IsNullOrWhiteSpace(hova))
                {
                    <small class="text-warning">Adj meg egy úticélt!</small>
                }
            </div>

            @* Utazás dátuma *@
            <div class="col-12 col-md-6 mx-auto">
                <label class="form-label text-white fw-semibold mb-2">
                    <i class="bi bi-calendar-event me-2"></i>
                    Mikor szeretnél utazni?
                </label>
                <input type="date"
                       class="form-control form-control-lg text-center"
                       @bind="tripStartDate"
                       min="@DateTime.Now.ToString("yyyy-MM-dd")">
            </div>
        </div>

        <p class="lead mb-4 opacity-75 mx-auto" style="max-width:520px">
            Tervezz személyre szabott utakat percek alatt. A TeUtad elkészíti a tökéletes útvonalat — a te ízlésed szerint.
        </p>

        <a href="/ut-tervezes?destination=@System.Web.HttpUtility.UrlEncode(hova)&date=@tripStartDate.ToString("yyyy-MM-dd")&from=@System.Web.HttpUtility.UrlEncode(honnan)"
           class="btn btn-warning btn-lg rounded-pill px-5 py-3 fw-bold shadow fs-5 @(string.IsNullOrWhiteSpace(hova) ? "disabled" : "")">
            <i class="bi bi-plus-circle me-2"></i>
            Út tervezésének indítása
        </a>

        @if (string.IsNullOrWhiteSpace(hova))
        {
            <div class="mt-3">
                <small class="text-white opacity-75">
                    <i class="bi bi-info-circle me-1"></i>
                    Adjon meg egy úticélt a tervezés indításához!
                </small>
            </div>
        }

    </div>
</section>

<!-- TRIP CARDS -->
<main class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Népszerű úticélok</h2>
            <p class="text-muted mb-0">Ezreket inspirált már a TeUtad</p>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var destination in destinations)
        {
            <div class="col-sm-6 col-lg-4">
                <div class="card trip-card border-0 shadow-sm rounded-4 overflow-hidden h-100"
                     @onmouseover="@(() => HandleCardHover(destination.Id, true))"
                     @onmouseout="@(() => HandleCardHover(destination.Id, false))">
                    <div class="destination-img bg-@destination.BadgeColor bg-gradient">@destination.Emoji</div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold mb-0">@destination.Name</h5>
                            <span class="badge bg-@destination.BadgeColor-subtle text-@destination.BadgeColor rounded-pill">
                                @GetBadgeText(destination.BadgeKey)
                            </span>
                        </div>
                        <p class="text-muted small mb-3">
                            <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                            @GetLocationText(destination.LocationKey)
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        <button class="btn btn-outline-primary btn-sm rounded-pill w-100" @onclick="@(() => SelectDestination(destination.Name))">
                            Ezt tervezem
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="text-center mt-4 d-md-none">
        <a href="#" class="btn btn-outline-primary rounded-pill px-4">
            Összes megtekintése <i class="bi bi-arrow-right ms-1"></i>
        </a>
    </div>

    <div class="card border-0 bg-primary text-white rounded-4 shadow mt-5">
        <div class="card-body text-center py-5">

            <h4 class="fw-bold mb-2">Álmodd meg a saját utazásod!</h4>
            <p class="opacity-75">Nem tetszik ezek közül egyik sem?</p>
            <p class="opacity-75"> Tekintsd meg az összes úticélunkat vagy ha kalandvágyó vagy kezdd el tervezni a saját utazásod!</p>
            <a href="/ut-tervezes?destination=@System.Web.HttpUtility.UrlEncode(hova)&date=@tripStartDate.ToString("yyyy-MM-dd")&from=@System.Web.HttpUtility.UrlEncode(honnan)"
               class="btn btn-warning btn-lg rounded-pill px-5 fw-bold shadow-sm @(string.IsNullOrWhiteSpace(hova) ? "disabled" : "")">
                <i class="bi bi-plus-circle me-2"></i>
                Út tervezésének indítása
            </a>
            @if (string.IsNullOrWhiteSpace(hova))
            {
                <div class="mt-3">
                    <small class="text-white opacity-75">
                        <i class="bi bi-info-circle me-1"></i>
                        Adjon meg egy úticélt fent a tervezés indításához!
                    </small>
                </div>
            }
        </div>
    </div>
</main>

<!-- FOOTER -->
<footer class="bg-white border-top mt-4 py-4">
    <div class="container">
        <div class="row align-items-center gy-3">
            <div class="col-md-4 text-center text-md-start">
                <span class="fw-bold fs-5">
                    <i class="bi bi-compass text-primary me-1"></i>Te<span class="text-primary">Utad</span>
                </span>
                <span class="text-muted small ms-2">— YourWay</span>
            </div>
        </div>
        <div class="text-center text-muted small mt-3">
            © 2025 TeUtad
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>


<script>

    function initAutocomplete() {
        initSimpleAutocomplete('index-destination-input');
        initSimpleAutocomplete('index-from-input');
        console.log("autocomplete ready")
    }

</script>



@code {
    string debug = "";
    string honnan = "";
    string hova = "";
    DateTime tripStartDate = DateTime.Now.AddDays(7);

    protected override void OnInitialized()
    {
        base.OnInitialized();

        // Megkeveri a kártyákat a főoldalon
        var random = new Random();
        destinations = allDestinations.OrderBy(x => random.Next()).ToList();


    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initAutocomplete");
        }

    }



    void uticelcsere()
    {
        var temp = honnan;
        honnan = hova;
        hova = temp;
        debug = "csere";
        StateHasChanged();
    }

    void SelectDestination(string destinationName)
    {
        hova = destinationName;
        StateHasChanged();

        // Scroll up to search box
        JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);
