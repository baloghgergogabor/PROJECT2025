@code {
    public string honnan { get; set; } = "";
    public string hova { get; set; } = "";
    DateTime tripStartDate = DateTime.Now.AddDays(7);

    private DotNetObjectReference<Index>? dotNetHelper;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            //await JSRuntime.InvokeVoidAsync("signalBlazorReady");
            await Task.Delay(1500); // Várunk a Google Maps betöltésére

            dotNetHelper = DotNetObjectReference.Create(this);

            try
            {
                await JSRuntime.InvokeVoidAsync("initSimpleAutocomplete",
                    "index-from-input", dotNetHelper, "SetHonnan");

                await JSRuntime.InvokeVoidAsync("initSimpleAutocomplete",
                    "index-destination-input", dotNetHelper, "SetHova");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Autocomplete init error: {ex.Message}");
            }

        }

    }
    void uticelcsere()
    {
        var temp = honnan;
        honnan = hova;
        hova = temp;

        StateHasChanged();
    }
    [JSInvokable]
    public void SetHonnan(string value)
    {
        honnan = value;
        StateHasChanged();
        Console.WriteLine($"✅ Honnan beállítva: {honnan}");
    }

    [JSInvokable]
    public void SetHova(string value)
    {
        hova = value;
        StateHasChanged();
        Console.WriteLine($"✅ Hova beállítva: {hova}");
    }

    public void Dispose()
    {
        dotNetHelper?.Dispose();

        // Pac-container eltávolítása body-ból oldalváltáskor
        _ = JSRuntime.InvokeVoidAsync("cleanupPacContainer");
    }

    private void UtIndtitas()
    {
        var hon = Uri.EscapeDataString(honnan ?? "");
        var hov = Uri.EscapeDataString(hova ?? "");
        var date = tripStartDate.ToString("yyyy-MM-dd");
        var uri = $"/ut-tervezes?from={hon}&destination={hov}&date={date}";
        nav.NavigateTo(uri);
    }
}
