@page "/ut-tervezes"
@inject NavigationManager NavigationManager
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using TeUtad.LIB.Modul
@using TeUtad.SERVICE
@using TeUtad.MODEL
@using TeUtad.LIB.Modul
@inject IJSRuntime JSRuntime
@inject FelhasznaloAuthState AuthStateProvider
@inject UtazasSzerviz UtazasSzerviz
@inject LatvanyossagokSzerviz LatvanyossagokSzerviz
@inject UtazasLatvanyossagSzerviz UtazasLatvanyossagSzerviz
@inject NavigationManager NavigationManager
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Út tervezése — TeUtad</PageTitle>

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />


    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyBL9wuHLIfIK1LLTkqPA6sW4ltfXl2rbfo&libraries=places&callback=Function.prototype" async defer></script>
    <script src="/js/googleMaps.js"></script>
</head>



<div class="container py-5">
    @* Dátumválasztó - Mobile-friendly *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3 p-md-4">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-3">
                    <label class="form-label fw-semibold mb-2">
                        <i class="bi bi-calendar-event me-2"></i>
                        Utazás kezdete
                    </label>
                    <input type="date"
                    class="form-control form-control-lg"
                    @bind="tripStartDate"
                    @bind:event="oninput"
                    @onchange="OnTripDateChanged" />
                </div>
                <div class="col-12 col-md-6">
                    <div class="alert alert-info mb-0 py-2 px-3 small">
                        <i class="bi bi-info-circle me-1"></i>
                        <strong>Kiválasztott dátum:</strong> @tripStartDate.ToString("yyyy. MMMM dd. (dddd)")
                        - Állomások automatikusan erre a napra lesznek tervezve
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    @if (currentUtazasId.HasValue)
                    {
                        <button type="button" class="btn btn-success btn-lg w-100" @onclick="SaveTrip" disabled="@isSaving">
                            <i class="bi bi-save me-2"></i>
                            @(isSaving ? "Mentés..." : "Változások mentése")
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary btn-lg w-100" @onclick="SaveTrip" disabled="@isSaving">
                            <i class="bi bi-save me-2"></i>
                            @(isSaving ? "Mentés..." : "Utazás mentése")
                        </button>
                    }
                </div>
            </div>
            @if (!string.IsNullOrEmpty(saveMessage))
            {
                <div class="alert @(saveSuccess ? "alert-success" : "alert-danger") mt-3 mb-0 py-2 px-3 small">
                    <i class="bi @(saveSuccess ? "bi-check-circle" : "bi-exclamation-circle") me-1"></i>
                    @saveMessage
                </div>
            }
        </div>
    </div>

    @* Lépésjelző *@
    <div class="step-indicator">
        <div class="step-item @(currentStep >= 1 ? "completed" : "") @(currentStep == 1 ? "active" : "")">
            <div class="step-circle">
                @if (currentStep > 1)
                {
                    <i class="bi bi-check-lg"></i>
                }
                else
                {

                    <span>1</span>
                }
            </div>
            <div class="small fw-semibold">Útvonal</div>
        </div>
        <div class="step-item @(currentStep >= 2 ? "completed" : "") @(currentStep == 2 ? "active" : "")">
            <div class="step-circle">
                @if (currentStep > 2)
                {
                    <i class="bi bi-check-lg"></i>
                }
                else
                {

                    <span>2</span>
                }
            </div>
            <div class="small fw-semibold">Repjegy</div>
        </div>
        <div class="step-item @(currentStep >= 3 ? "completed" : "") @(currentStep == 3 ? "active" : "")">
            <div class="step-circle">
                @if (currentStep > 3)
                {
                    <i class="bi bi-check-lg"></i>
                }
                else
                {

                    <span>3</span>
                }
            </div>
            <div class="small fw-semibold">Szállás</div>
        </div>
        <div class="step-item @(currentStep == 4 ? "active" : "")">
            <div class="step-circle">4</div>
            <div class="small fw-semibold">Autóbérlés</div>
        </div>
    </div>

    @* Fő tartalom kártya *@
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-md-5">

            @if (currentStep == 1)
            {
                @* 1. LÉPÉS: Útvonaltervezés *@
                <h2 class="fw-bold mb-4">
                    <i class="bi bi-map me-2 text-primary"></i>
                    Útvonal tervezése
                </h2>

                <div class="row">
                    <div class="col-lg-4 mb-4 mb-lg-0">
                        <h5 class="fw-semibold mb-3">Útvonal pontok</h5>

                        @* Autocomplete keresés *@
                        <div class="mb-3">
                            <label class="form-label small text-muted">
                                <i class="bi bi-search me-1"></i>
                                Új helyszín keresése
                            </label>
                            <input type="text"
                            id="autocomplete-input"
                            class="form-control"
                            placeholder="Pl. Halászbástya, Parlament..." />
                            <small class="text-muted m-3">Kezdj el gépelni és válassz a listából!</small>
                        </div>

                        <hr class="my-3" />

                        @* Útvonalpontok listája *@
                        @foreach (var point in routePoints)
                        {
                            var pointColor = GetPointColor(point.Order);
                            <div class="route-point" style="border-left: 4px solid @pointColor;">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="flex-grow-1">
                                        <div class="small" style="color: @pointColor; font-weight: 600;">
                                            <span style="display: inline-block; width: 24px; height: 24px; background: @pointColor; color: white; border-radius: 50%; text-align: center; line-height: 24px; font-size: 12px; font-weight: bold;">
                                                @point.Order
                                            </span>
                                            @point.Order. állomás
                                        </div>
                                        <div class="fw-bold">@point.AttractionName</div>
                                        <div class="small text-muted">
                                            <i class="bi bi-geo-alt me-1"></i>@point.Address
                                        </div>
                                        <span class="badge mt-1" style="background-color: @pointColor; color: white;">@point.Category</span>

                                        @* Nyitvatartási idő *@
                                        @if (!string.IsNullOrEmpty(point.OpeningHours))
                                        {
                                            <div class="small mt-2">
                                                <i class="bi bi-clock me-1"></i>
                                                <span class="@(point.IsOpen == true ? "text-success" : point.IsOpen == false ? "text-danger" : "text-muted")">
                                                    @point.OpeningHours
                                                </span>
                                            </div>
                                        }
                                    </div>

                                    <div class="d-flex flex-column gap-1">
                                        @* Fel/Le gombok *@
                                        @if (point.Order > 1)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-secondary" 
                                            @onclick="@(() => MovePointUp(point.Id))"
                                            title="Fel">
                                                <i class="bi bi-arrow-up"></i>
                                            </button>
                                        }
                                        @if (point.Order < routePoints.Count)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-secondary" 
                                            @onclick="@(() => MovePointDown(point.Id))"
                                            title="Le">
                                                <i class="bi bi-arrow-down"></i>
                                            </button>
                                        }
                                        <button type="button" class="btn btn-sm btn-outline-danger" 
                                        @onclick="@(() => RemoveRoutePoint(point.Id))"
                                        title="Törlés">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>

                                @* Zárva figyelmeztetés *@
                                @if (point.WillBeClosed)
                                {
                                    <div class="alert alert-warning py-2 px-3 mb-2 small">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                        <strong>Figyelem!</strong> A Google Maps szerint ez a lokáció már zárva lesz mire odaérnél!
                                    </div>
                                }

                                <div class="small mb-2">
                                    <i class="bi bi-calendar me-1"></i>
                                    @point.VisitDate.ToString("yyyy. MM. dd.")
                                    <i class="bi bi-clock ms-2 me-1"></i>
                                    @point.StartTime.ToString(@"hh\:mm") - @point.EndTime.ToString(@"hh\:mm")
                                </div>

                                @* Időtartam beállítás - Mobilbarát *@
                                <div class="border border-secondary rounded-3 m-2 px-2 px-md-3 py-2">
                                    <p class="fw-semibold m-0 small mb-2 mb-md-0">Mennyi időt tervezel itt tartózkodni?</p>
                                    <div class="d-flex align-items-center justify-content-center gap-2">
                                        <button class="btn btn-primary btn-sm" @onclick="@(() => DecreaseTime(point))">
                                            <i class="bi bi-dash"></i>
                                        </button>
                                        <span class="fw-bold mx-2">@point.TimeBefore óra</span>
                                        <button class="btn btn-primary btn-sm" @onclick="@(() => IncreaseTime(point))">
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            @* Közlekedési mód választás (csak ha nem az utolsó pont) *@
                            @if (point.Order < routePoints.Count)
                            {
                                <div class="border border-warning rounded-3 m-2 mb-3 p-3 bg-light">
                                    <p class="fw-semibold mb-2 small">
                                        <i class="bi bi-arrow-right-circle me-1"></i>
                                        Hogyan jutsz el a következő állomásra?
                                    </p>

                                    @* Közlekedési opciók *@
                                    <div class="row g-2 mb-2">
                                        @foreach (var mode in new[] { 
                                            ("DRIVING", "car-front", "Autó", "primary"),
                                            ("WALKING", "person-walking", "Gyalog", "success"),
                                            ("BICYCLING", "bicycle", "Kerékpár", "info"),
                                            ("TRANSIT", "bus-front", "Tömegközl.", "warning")
                                        })
                                        {
                                            var (modeKey, icon, label, color) = mode;
                                            var isSelected = point.TravelModeToNext == modeKey;
                                            var hasInfo = point.TravelOptions.ContainsKey(modeKey);

                                            <div class="col-6 col-md-3">
                                                <button type="button" 
                                                class="btn @(isSelected ? $"btn-{color}" : $"btn-outline-{color}") btn-sm w-100 position-relative"
                                                @onclick="@(() => SelectTravelMode(point, modeKey))">
                                                    <i class="bi bi-@icon d-block mb-1"></i>
                                                    <small class="d-block">@label</small>
                                                    @if (hasInfo && point.TravelOptions[modeKey].Duration != "...")
                                                    {
                                                        <small class="d-block fw-bold">@point.TravelOptions[modeKey].Duration</small>
                                                        <small class="d-block text-muted" style="font-size: 0.7em;">@point.TravelOptions[modeKey].Distance</small>
                                                    }
                                                    else if (!hasInfo)
                                                    {
                                                        <div class="spinner-border spinner-border-sm mt-1" role="status">
                                                            <span class="visually-hidden">Számítás...</span>
                                                        </div>
                                                    }
                                                </button>
                                            </div>
                                        }
                                    </div>

                                    @* Összehasonlítás gomb *@
                                    @if (point.TravelOptions.Count == 4 && point.TravelOptions.All(x => x.Value.Duration != "..."))
                                    {
                                        <div class="alert alert-info mb-0 py-2 small">
                                            <i class="bi bi-info-circle me-1"></i>
                                            <strong>Leggyorsabb:</strong> 
                                            @{
                                                var fastest = point.TravelOptions.OrderBy(x => x.Value.DurationMinutes).First();
                                                var fastestLabel = fastest.Key switch {
                                                    "DRIVING" => "Autó",
                                                    "WALKING" => "Gyalog",
                                                    "BICYCLING" => "Kerékpár",
                                                    "TRANSIT" => "Tömegközlekedés",
                                                    _ => fastest.Key
                                                };
                                            }
                                            @fastestLabel (@fastest.Value.Duration, @fastest.Value.Distance)
                                        </div>
                                    }

                                    @* Tömegközlekedési részletek *@
                                    @if (point.TravelModeToNext == "TRANSIT" && 
                                    point.TravelOptions.ContainsKey("TRANSIT") && 
                                    point.TravelOptions["TRANSIT"].TransitDetails != null)
                                    {
                                        var transit = point.TravelOptions["TRANSIT"].TransitDetails;
                                        <div class="alert alert-info mb-0 p-2 small mt-2">
                                            <div class="fw-bold mb-1">
                                                <i class="bi bi-info-circle me-1"></i>Útvonal részletei:
                                            </div>
                                            @foreach (var step in transit.Steps)
                                            {
                                                <div class="mb-2">
                                                    @if (step.TravelMode == "TRANSIT")
                                                    {
                                                        <div>
                                                            <i class="bi bi-@GetTransitIcon(step.VehicleType) me-1"></i>
                                                            <strong>@step.LineName</strong> irány: @step.HeadSign
                                                        </div>
                                                        <div class="ms-3 text-muted small">
                                                            <div>Felszállás: @step.DepartureStop (@step.DepartureTime)</div>
                                                            <div>Leszállás: @step.ArrivalStop (@step.ArrivalTime)</div>
                                                            <div>@step.NumStops megálló (@step.Duration)</div>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div>
                                                            <i class="bi bi-person-walking me-1"></i>
                                                            Gyalog @step.Distance (@step.Duration)
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            <hr />
                        }

                        @* Statisztikák *@
                        <div class="mt-4 p-3 bg-light rounded">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Helyszínek száma:</span>
                                <span class="fw-bold">@routePoints.Count db</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Teljes időtartam:</span>
                                <span class="fw-bold">@totalHours óra</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Látogatási napok:</span>
                                <span class="fw-bold">@totalDays nap</span>
                            </div>
                        </div>
                    </div>

                    @* Google Maps térkép *@
                    <div class="col-lg-8">
                        <div id="map"></div>

                        @* Útvonal részletek a térképen *@
                        <div id="route-details-panel" class="mt-3 p-3 bg-light rounded" style="max-height: 200px; overflow-y: auto; display: none;">
                            <h6 class="fw-bold mb-2">
                                <i class="bi bi-route me-2"></i>Útvonal részletei
                            </h6>
                            <div id="route-details-content"></div>
                        </div>

                        <p class="small text-muted mt-2 text-center">
                            <i class="bi bi-info-circle me-1"></i>
                            Kattints a markerekre a részletekért
                        </p>
                    </div>
                </div>
            }

            @if (currentStep == 2)
            {
                @* 2. LÉPÉS: Repjegy kiválasztása *@
                <h2 class="fw-bold mb-4">
                    <i class="bi bi-airplane me-2 text-primary"></i>
                    Repjegy kiválasztása
                </h2>

                <div class="row g-4">
                    @foreach (var flight in availableFlights)
                    {
                        <div class="col-md-6">
                            <div class="card flight-card border rounded-4 h-100 position-relative @(selectedFlightId == flight.Id ? "selected" : "")"
                            @onclick="@(() => SelectFlight(flight.Id))">
                                <div class="price-badge">@flight.Price Ft</div>
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="bg-primary bg-opacity-10 rounded-circle p-2 me-3">
                                            <i class="bi bi-airplane-fill text-primary fs-4"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold">@flight.Airline</div>
                                            <div class="small text-muted">@flight.FlightNumber</div>
                                        </div>
                                    </div>

                                    <div class="row align-items-center mb-3">
                                        <div class="col">
                                            <div class="fw-bold fs-5">@flight.DepartureTime</div>
                                            <div class="text-muted">@flight.DepartureCity</div>
                                        </div>
                                        <div class="col-auto">
                                            <div class="text-center">
                                                <i class="bi bi-arrow-right text-primary"></i>
                                                <div class="small text-muted">@flight.Duration</div>
                                            </div>
                                        </div>
                                        <div class="col text-end">
                                            <div class="fw-bold fs-5">@flight.ArrivalTime</div>
                                            <div class="text-muted">@flight.ArrivalCity</div>
                                        </div>
                                    </div>

                                    <div class="d-flex gap-2">
                                        <span class="badge bg-success-subtle text-success">@flight.Class</span>
                                        @if (flight.DirectFlight)
                                        {
                                            <span class="badge bg-primary-subtle text-primary">Direkt járat</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning-subtle text-warning">@flight.Stops átszállás</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @* Kihagy opció *@
                    <div class="col-12">
                        <div class="skip-option" @onclick="@(() => selectedFlightId = null)">
                            <i class="bi bi-x-circle display-6 text-muted mb-2"></i>
                            <p class="mb-0 fw-semibold">Nincs szükségem repjegyre</p>
                            <small class="text-muted">Saját járatot foglalok vagy más közlekedési eszközt használok</small>
                        </div>
                    </div>
                </div>
            }

            @if (currentStep == 3)
            {
                @* 3. LÉPÉS: Szállás kiválasztása *@
                <h2 class="fw-bold mb-4">
                    <i class="bi bi-building me-2 text-primary"></i>
                    Szállás kiválasztása
                </h2>

                <div class="row g-4">
                    @foreach (var hotel in availableHotels)
                    {
                        <div class="col-md-6">
                            <div class="card hotel-card border rounded-4 h-100 position-relative @(selectedHotelId == hotel.Id ? "selected" : "")"
                            @onclick="@(() => SelectHotel(hotel.Id))">
                                <div class="price-badge">@hotel.PricePerNight Ft / éj</div>
                                <div class="card-body p-4">
                                    <div class="mb-3">
                                        <h5 class="fw-bold mb-1">@hotel.Name</h5>
                                        <div class="text-muted small">
                                            <i class="bi bi-geo-alt-fill me-1"></i>@hotel.Location
                                        </div>
                                        <div class="mt-2">
                                            @for (int i = 0; i < hotel.Stars; i++)
                                            {
                                                <i class="bi bi-star-fill text-warning"></i>
                                            }
                                            <span class="ms-2 small text-muted">(@hotel.Rating / 10)</span>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var amenity in hotel.Amenities)
                                            {
                                                <span class="badge bg-secondary-subtle text-secondary">
                                                    <i class="bi bi-check-circle me-1"></i>@amenity
                                                </span>
                                            }
                                        </div>
                                    </div>

                                    <div class="small text-muted">
                                        <i class="bi bi-people me-1"></i>
                                        Max @hotel.MaxGuests fő · @hotel.RoomType
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @* Kihagy opció *@
                    <div class="col-12">
                        <div class="skip-option" @onclick="@(() => selectedHotelId = null)">
                            <i class="bi bi-x-circle display-6 text-muted mb-2"></i>
                            <p class="mb-0 fw-semibold">Nincs szükségem szállásra</p>
                            <small class="text-muted">Barátaimnál / családnál szállok meg vagy saját magam foglalom</small>
                        </div>
                    </div>
                </div>
            }

            @if (currentStep == 4)
            {
                @* 4. LÉPÉS: Autóbérlés *@
                <h2 class="fw-bold mb-4">
                    <i class="bi bi-car-front me-2 text-primary"></i>
                    Autóbérlés
                </h2>

                <div class="row g-4">
                    @foreach (var car in availableCars)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card car-card border rounded-4 h-100 position-relative @(selectedCarId == car.Id ? "selected" : "")"
                            @onclick="@(() => SelectCar(car.Id))">
                                <div class="price-badge">@car.PricePerDay Ft / nap</div>
                                <div class="card-body p-4">
                                    <div class="text-center mb-3">
                                        <div class="display-1">@car.Icon</div>
                                        <h5 class="fw-bold mb-1">@car.Model</h5>
                                        <div class="text-muted small">@car.Brand</div>
                                    </div>

                                    <div class="d-flex justify-content-around text-center mb-3">
                                        <div>
                                            <i class="bi bi-people text-muted"></i>
                                            <div class="small">@car.Seats fő</div>
                                        </div>
                                        <div>
                                            <i class="bi bi-briefcase text-muted"></i>
                                            <div class="small">@car.Luggage db</div>
                                        </div>
                                        <div>
                                            <i class="bi bi-gear text-muted"></i>
                                            <div class="small">@car.Transmission</div>
                                        </div>
                                    </div>

                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var feature in car.Features)
                                        {
                                            <span class="badge bg-info-subtle text-info small">@feature</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @* Kihagy opció *@
                    <div class="col-12">
                        <div class="skip-option" @onclick="@(() => selectedCarId = null)">
                            <i class="bi bi-x-circle display-6 text-muted mb-2"></i>
                            <p class="mb-0 fw-semibold">Nincs szükségem autóbérlésre</p>
                            <small class="text-muted">Tömegközlekedést használok vagy saját autóval megyek</small>
                        </div>
                    </div>
                </div>
            }

            @* Navigációs gombok *@
            <div class="d-flex justify-content-between mt-5 pt-4 border-top">
                @if (currentStep > 1)
                {
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" @onclick="PreviousStep">
                        <i class="bi bi-arrow-left me-2"></i>
                        Vissza
                    </button>
                }
                else
                {
                    <div></div>
                }

                @if (currentStep < 4)
                {
                    <button type="button" class="btn btn-primary rounded-pill px-4" @onclick="NextStep">
                        Tovább
