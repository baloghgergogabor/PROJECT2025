            var routeData = routePoints.Select(p => new
            {
                attractionName = p.AttractionName,
                address = p.Address,
                latitude = p.Latitude,
                longitude = p.Longitude,
                startTime = p.StartTime.ToString(@"hh\:mm"),
                endTime = p.EndTime.ToString(@"hh\:mm")
            }).ToArray();

            await JSRuntime.InvokeVoidAsync("initMap", (object)routeData, "map");
            Console.WriteLine($"✅ Térkép inicializálva {routePoints.Count} ponttal");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ InitializeMap error: {ex.Message}");
        }
    }

    // === Térkép frissítése ===
    private async Task UpdateMap()
    {
        try
        {
            // FONTOS: Objektum tömb létrehozása, NEM közvetlenül a routePoints!
            var routeData = routePoints.Select(p => new
            {
                attractionName = p.AttractionName,
                address = p.Address,
                latitude = p.Latitude,
                longitude = p.Longitude,
                startTime = p.StartTime.ToString(@"hh\:mm"),
                endTime = p.EndTime.ToString(@"hh\:mm"),
                travelModeToNext = p.TravelModeToNext
            }).ToArray();

            // Cast object-re, hogy biztosan tömbként menjen át
            await JSRuntime.InvokeVoidAsync("updateMap", (object)routeData);
            Console.WriteLine($"✅ Térkép frissítve {routePoints.Count} ponttal");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ UpdateMap error: {ex.Message}");
        }
    }

    // === AUTOCOMPLETE CALLBACK - JavaScript hívja meg ===
    [JSInvokable]
    public async Task OnPlaceSelected(UtTervezeshez.PlaceData placeData)
    {
        try
        {
            // Utolsó pont lekérése
            var lastPoint = routePoints.LastOrDefault();
            var newVisitDate = lastPoint?.VisitDate ?? tripStartDate;
            var newStartTime = lastPoint?.EndTime.Add(TimeSpan.FromHours(1)) ?? new TimeSpan(9, 0, 0);

            // Ha már késő van, következő napra tesszük
            if (newStartTime.TotalHours >= 22)
            {
                newVisitDate = newVisitDate.AddDays(1);
                newStartTime = new TimeSpan(9, 0, 0);
            }

            // Új pont hozzáadása
            var newPoint = new RoutePoint
            {
                Id = routePoints.Any() ? routePoints.Max(p => p.Id) + 1 : 1,
                Order = routePoints.Count + 1,
                AttractionName = placeData.Name,
                Address = placeData.Address,
                VisitDate = newVisitDate,
                StartTime = newStartTime,
                EndTime = newStartTime.Add(TimeSpan.FromHours(2)),
                Category = "Látnivaló",
                Latitude = placeData.Latitude,
                Longitude = placeData.Longitude,
                PlaceId = placeData.PlaceId,
                TimeBefore = 2,
                TravelModeToNext = "WALKING"
            };

            routePoints.Add(newPoint);

            // Nyitvatartási idő ellenőrzése
            await CheckOpeningHours(newPoint);

            // Ha volt előző pont, számoljuk ki az összes utazási módot
            if (lastPoint != null)
            {
                await CalculateAllTravelModes(lastPoint);
            }

            RecalculateTotals();
            await UpdateMap();

            // Input mező ürítése
            await JSRuntime.InvokeVoidAsync("eval",
                "document.getElementById('autocomplete-input').value = ''");

            StateHasChanged();

            Console.WriteLine($"✅ Új hely hozzáadva: {placeData.Name}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ OnPlaceSelected error: {ex.Message}");
        }
    }

    // === Útvonalpont törlése ===
    private async Task RemoveRoutePoint(int id)
    {
        try
        {
            var point = routePoints.FirstOrDefault(p => p.Id == id);
            if (point != null && routePoints.Count > 1)
            {
                routePoints.Remove(point);

                // Sorrend újraszámozása
                for (int i = 0; i < routePoints.Count; i++)
                {
                    routePoints[i].Order = i + 1;
                }

                RecalculateTotals();
                await UpdateMap();
                StateHasChanged();

                Console.WriteLine($"✅ Pont törölve: {point.AttractionName}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ RemoveRoutePoint error: {ex.Message}");
        }
    }

    // === Statisztikák újraszámolása ===
    private void RecalculateTotals()
    {
        if (routePoints.Any())
        {
            var firstDate = routePoints.Min(p => p.VisitDate);
            var lastDate = routePoints.Max(p => p.VisitDate);
            totalDays = (lastDate - firstDate).Days + 1;

            double totalMinutes = 0;
            foreach (var point in routePoints)
            {
                totalMinutes += (point.EndTime - point.StartTime).TotalMinutes;
            }
            totalHours = (int)(totalMinutes / 60);
        }
        else
        {
            totalDays = 0;
            totalHours = 0;
        }
    }

