    // === UTAZÁS MENTÉSE ===
    private async Task SaveTrip()
    {
        try
        {
            isSaving = true;
            saveMessage = "";
            StateHasChanged();

            // Ellenőrizzük, hogy be van-e jelentkezve a felhasználó
            if (!currentFelhasznaloId.HasValue)
            {
                saveMessage = "A mentéshez be kell jelentkezned!";
                saveSuccess = false;
                isSaving = false;
                StateHasChanged();
                return;
            }

            // Ellenőrizzük, hogy van-e legalább egy útvonalpont
            if (!routePoints.Any())
            {
                saveMessage = "Legalább egy helyszínt adj hozzá az útvonalhoz!";
                saveSuccess = false;
                isSaving = false;
                StateHasChanged();
                return;
            }

            // 1. Utazás rekord létrehozása vagy frissítése
            Utazas utazas;
            if (currentUtazasId.HasValue)
            {
                // Meglévő utazás frissítése
                utazas = await UtazasSzerviz.GetByIdUtazas(currentUtazasId.Value);
                if (utazas == null)
                {
                    saveMessage = "A mentett utazás nem található!";
                    saveSuccess = false;
                    isSaving = false;
                    StateHasChanged();
                    return;
                }
            }
            else
            {
                // Új utazás létrehozása
                utazas = new Utazas
                {
                    FelhasznaloId = currentFelhasznaloId.Value,
                    UtazasKezdes = DateOnly.FromDateTime(tripStartDate),
                    HotelId = selectedHotelId ?? null,
                    AutoId = selectedCarId ?? null,
                    RepuloJegyId = selectedFlightId ?? null
                };
                await UtazasSzerviz.PostUtazas(utazas);
                var Utazasok = await UtazasSzerviz.GetAllUtazas();
                currentUtazasId = Utazasok.FirstOrDefault(x => x.FelhasznaloId == utazas.FelhasznaloId).id;
            }

            // Frissítjük az utazás adatait
            utazas.UtazasKezdes = DateOnly.FromDateTime(tripStartDate);
            utazas.HotelId = selectedHotelId ?? 0;
            utazas.AutoId = selectedCarId ?? 0;
            utazas.RepuloJegyId = selectedFlightId ?? 0;
            await UtazasSzerviz.UpdateUtazas(utazas);

            // 2. Töröljük a régi útvonalpontokat ehhez az utazáshoz
            var existingPoints = await UtazasLatvanyossagSzerviz.GetAllUtazasLatvanyossag();
            var pointsToDelete = existingPoints.Where(p => p.UtazasId == currentUtazasId.Value).ToList();
            foreach (var point in pointsToDelete)
            {
                await UtazasLatvanyossagSzerviz.DeleteUtazasLatvanyossag(point.Id);
            }

            // 3. Mentsük el az útvonalpontokat
            foreach (var routePoint in routePoints)
            {
                // Először ellenőrizzük/létrehozzuk a látnivalóságot
                int latvanyossagId = await GetOrCreateLatvanyossag(routePoint);

                // Létrehozzuk a kapcsolótábla bejegyzést
                var utazasLatvanyossag = new UtazasLatvanyossag
                {
                    UtazasId = currentUtazasId.Value,
                    LatvanyossagId = latvanyossagId,
                    Sorrend = routePoint.Order,
                    TartozkodasIdoOra = routePoint.TimeBefore,
                    LatogatasDatum = routePoint.VisitDate,
                    KezdesIdo = routePoint.StartTime,
                    BefejezesIdo = routePoint.EndTime,
                    UtazasiModKovetkezohoz = routePoint.TravelModeToNext
                };

                await UtazasLatvanyossagSzerviz.PostUtazasLatvanyossag(utazasLatvanyossag);
            }

            saveMessage = currentUtazasId.HasValue ? "Utazás sikeresen frissítve!" : "Utazás sikeresen elmentve!";
            saveSuccess = true;

            // Frissítjük az URL-t, hogy tartalmazza a tripId-t (így újratöltéskor is betöltődik)
            if (!TripIdQuery.HasValue || TripIdQuery.Value != currentUtazasId.Value)
            {
                NavigationManager.NavigateTo($"/ut-tervezes?tripId={currentUtazasId.Value}", forceLoad: false);
            }

            Console.WriteLine($"✅ Utazás mentve! ID: {currentUtazasId.Value}");
        }
        catch (Exception ex)
        {
            saveMessage = $"Hiba történt a mentés során: {ex.Message}";
            saveSuccess = false;
            Console.WriteLine($"❌ SaveTrip error: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();

            // Üzenet automatikus eltüntetése 5 másodperc után
            await Task.Delay(5000);
            saveMessage = "";
            StateHasChanged();
        }
    }

    // === Látnivalóság lekérése vagy létrehozása ===
    private async Task<int> GetOrCreateLatvanyossag(RoutePoint routePoint)
    {
        try
        {
            // Először megpróbáljuk megkeresni GoogleMapsId alapján
            if (!string.IsNullOrEmpty(routePoint.PlaceId))
            {
                var allLatvanyossagok = await LatvanyossagokSzerviz.GetAllLatvanyossagok();
                var existing = allLatvanyossagok.FirstOrDefault(l => l.GoogleMapsId == routePoint.PlaceId);

                if (existing != null)
                {
                    return existing.id;
                }
            }

            // Ha nem találtuk meg, létrehozunk egy újat
            var newLatvanyossag = new Latvanyossagok
            {
                Latvanyossag = routePoint.AttractionName,
                Cim = routePoint.Address,
                GoogleMapsId = routePoint.PlaceId ?? "",
                UNESCO = false // Ezt később frissíthetjük, ha van UNESCO információnk
            };

            await LatvanyossagokSzerviz.PostLatvanyossagok(newLatvanyossag);
            return newLatvanyossag.id;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ GetOrCreateLatvanyossag error: {ex.Message}");
            throw;
        }
    }

    // === UTAZÁS BETÖLTÉSE ===
    private async Task LoadTrip(int tripId)
    {
        try
        {
            Console.WriteLine($"📖 Utazás betöltése: {tripId}");

            // 1. Betöltjük az utazás alapadatait
            var utazas = await UtazasSzerviz.GetByIdUtazas(tripId);
            if (utazas == null)
            {
                saveMessage = "Az utazás nem található!";
                saveSuccess = false;
                StateHasChanged();
                return;
            }

            // Ellenőrizzük, hogy a felhasználóé-e az utazás
            if (currentFelhasznaloId.HasValue && utazas.FelhasznaloId != currentFelhasznaloId.Value)
            {
                saveMessage = "Nincs jogosultságod ehhez az utazáshoz!";
                saveSuccess = false;
                StateHasChanged();
                return;
            }

            // 2. Beállítjuk az alapadatokat
            currentUtazasId = tripId;
            tripStartDate = utazas.UtazasKezdes.ToDateTime(TimeOnly.MinValue);
            selectedHotelId = utazas.HotelId > 0 ? utazas.HotelId : null;
            selectedCarId = utazas.AutoId > 0 ? utazas.AutoId : null;
            selectedFlightId = utazas.RepuloJegyId > 0 ? utazas.RepuloJegyId : null;

            // 3. Betöltjük az útvonalpontokat
            var allUtazasLatvanyossagok = await UtazasLatvanyossagSzerviz.GetAllUtazasLatvanyossag();
            var utazasPoints = allUtazasLatvanyossagok
                .Where(ul => ul.UtazasId == tripId)
                .OrderBy(ul => ul.Sorrend)
                .ToList();

            // 4. Kiürítjük a jelenlegi útvonalpontokat
            routePoints.Clear();

            // 5. Hozzáadjuk a betöltött pontokat
            int pointId = 1;
            foreach (var utazasLatvanyossag in utazasPoints)
            {
                var latvanyossag = await LatvanyossagokSzerviz.GetByIdLatvanyossagok(utazasLatvanyossag.LatvanyossagId);
                if (latvanyossag == null) continue;

                // Ha van GoogleMapsId, megpróbáljuk lekérni a részletes információkat
                double latitude = 0;
                double longitude = 0;
                string placeId = latvanyossag.GoogleMapsId ?? "";

                // TODO: Geocode címből, ha nincsenek koordináták
                // Ez a GeocodeResult-ot használhatja, ha szükséges

                var routePoint = new RoutePoint
                {
                    Id = pointId++,
                    Order = utazasLatvanyossag.Sorrend,
                    AttractionName = latvanyossag.Latvanyossag,
                    Address = latvanyossag.Cim,
                    Latitude = latitude,
                    Longitude = longitude,
                    PlaceId = placeId,
                    VisitDate = utazasLatvanyossag.LatogatasDatum,
                    StartTime = utazasLatvanyossag.KezdesIdo,
                    EndTime = utazasLatvanyossag.BefejezesIdo,
                    TimeBefore = utazasLatvanyossag.TartozkodasIdoOra,
                    TravelModeToNext = utazasLatvanyossag.UtazasiModKovetkezohoz,
                    Category = "Látnivaló"
                };

                routePoints.Add(routePoint);
            }

            // 6. Ha vannak pontok, geocodoljuk őket a koordináták megszerzéséhez
            foreach (var point in routePoints)
            {
                if (point.Latitude == 0 && point.Longitude == 0 && !string.IsNullOrEmpty(point.Address))
                {
                    try
                    {
                        var geocodeResult = await JSRuntime.InvokeAsync<GeocodeResult>("geocodeAddress", point.Address);
                        if (geocodeResult != null)
                        {
                            point.Latitude = geocodeResult.Latitude;
                            point.Longitude = geocodeResult.Longitude;
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"⚠️ Geocoding failed for {point.Address}: {ex.Message}");
                    }
                }
            }

            RecalculateTotals();
            StateHasChanged();

            saveMessage = "Utazás sikeresen betöltve!";
            saveSuccess = true;

            Console.WriteLine($"✅ Utazás betöltve: {routePoints.Count} pont");

            // Üzenet eltüntetése
            await Task.Delay(3000);
            saveMessage = "";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            saveMessage = $"Hiba történt a betöltés során: {ex.Message}";
            saveSuccess = false;
            Console.WriteLine($"❌ LoadTrip error: {ex.Message}");
            StateHasChanged();
        }
    }

