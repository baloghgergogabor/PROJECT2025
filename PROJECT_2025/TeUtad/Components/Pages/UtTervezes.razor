    // === Utazási idő számítása Google Distance Matrix API-val ===
    private async Task CalculateTravelTime(RoutePoint fromPoint, string travelMode)
    {
        try
        {
            var toPoint = routePoints.FirstOrDefault(p => p.Order == fromPoint.Order + 1);
            if (toPoint == null) return;

            var result = await JSRuntime.InvokeAsync<TravelInfo>(
                "calculateTravelTime",
                fromPoint.Latitude,
                fromPoint.Longitude,
                toPoint.Latitude,
                toPoint.Longitude,
                travelMode
            );

            if (!fromPoint.TravelOptions.ContainsKey(travelMode))
            {
                fromPoint.TravelOptions[travelMode] = result;
            }
            else
            {
                fromPoint.TravelOptions[travelMode] = result;
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Travel time calculation error: {ex.Message}");
        }
    }

