    }

    // === Dátum változás kezelése ===
    private void OnTripDateChanged()
    {
        // Összes állomás dátumának frissítése
        foreach (var point in routePoints)
        {
            point.VisitDate = tripStartDate;
        }

        // Nyitvatartási idők újraellenőrzése
        foreach (var point in routePoints)
        {
            _ = CheckOpeningHours(point);
        }

        StateHasChanged();
    }

    // === Állomás fel/le mozgatása ===
    private async Task MovePointUp(int pointId)
    {
        var point = routePoints.FirstOrDefault(p => p.Id == pointId);
        if (point == null || point.Order <= 1) return;

        var prevPoint = routePoints.FirstOrDefault(p => p.Order == point.Order - 1);
        if (prevPoint == null) return;

        // Sorrend csere
        (point.Order, prevPoint.Order) = (prevPoint.Order, point.Order);

        // Lista rendezése
        routePoints = routePoints.OrderBy(p => p.Order).ToList();

        // Újraszámítás
        await RecalculateAfterReorder();
    }

    private async Task MovePointDown(int pointId)
    {
        var point = routePoints.FirstOrDefault(p => p.Id == pointId);
        if (point == null || point.Order >= routePoints.Count) return;

        var nextPoint = routePoints.FirstOrDefault(p => p.Order == point.Order + 1);
        if (nextPoint == null) return;

        // Sorrend csere
        (point.Order, nextPoint.Order) = (nextPoint.Order, point.Order);

        // Lista rendezése
        routePoints = routePoints.OrderBy(p => p.Order).ToList();

        // Újraszámítás
        await RecalculateAfterReorder();
    }

    private async Task RecalculateAfterReorder()
    {
        // Utazási idők újraszámítása
        for (int i = 0; i < routePoints.Count - 1; i++)
        {
            var currentPoint = routePoints[i];
            currentPoint.TravelOptions.Clear();
            await CalculateAllTravelModes(currentPoint);
        }

        RecalculateSchedule();
        await UpdateMap();
        StateHasChanged();
    }

    // === Időtartam változás ===
    private async Task IncreaseTime(RoutePoint point)
    {
        point.TimeBefore++;
        point.EndTime = point.StartTime.Add(TimeSpan.FromHours(point.TimeBefore));
        RecalculateSchedule();
        await CheckOpeningHours(point);
        StateHasChanged();
    }

    private async Task DecreaseTime(RoutePoint point)
    {
        if (point.TimeBefore > 1)
        {
            point.TimeBefore--;
            point.EndTime = point.StartTime.Add(TimeSpan.FromHours(point.TimeBefore));
            RecalculateSchedule();
            await CheckOpeningHours(point);
            StateHasChanged();
        }
    }

    // === Menetrend újraszámítása ===
    private void RecalculateSchedule()
    {
        for (int i = 1; i < routePoints.Count; i++)
        {
            var prevPoint = routePoints[i - 1];
            var currentPoint = routePoints[i];

            if (prevPoint.TravelOptions.ContainsKey(prevPoint.TravelModeToNext))
            {
                var travelMinutes = prevPoint.TravelOptions[prevPoint.TravelModeToNext].DurationMinutes;
                currentPoint.StartTime = prevPoint.EndTime.Add(TimeSpan.FromMinutes(travelMinutes));
            }
            else
            {
                currentPoint.StartTime = prevPoint.EndTime.Add(TimeSpan.FromMinutes(30));
            }

            currentPoint.EndTime = currentPoint.StartTime.Add(TimeSpan.FromHours(currentPoint.TimeBefore));

            if (currentPoint.StartTime.TotalHours >= 22)
            {
                currentPoint.VisitDate = prevPoint.VisitDate.AddDays(1);
                currentPoint.StartTime = new TimeSpan(9, 0, 0);
                currentPoint.EndTime = currentPoint.StartTime.Add(TimeSpan.FromHours(currentPoint.TimeBefore));
            }
        }

        RecalculateTotals();
    }

    // === Nyitvatartási idő ellenőrzése ===
    private async Task CheckOpeningHours(RoutePoint point)
    {
        if (string.IsNullOrEmpty(point.PlaceId)) return;

        try
        {
            var placeDetails = await JSRuntime.InvokeAsync<UtTervezeshez.PlaceDetails>(
                "getPlaceOpeningHours",
                point.PlaceId
            );

            if (placeDetails != null)
            {
                point.OpeningHours = placeDetails.OpeningHoursText ?? "";
                point.IsOpen = placeDetails.IsOpenNow;

                if (placeDetails.OpeningPeriods != null && placeDetails.OpeningPeriods.Any())
                {
                    var arrivalDay = (int)point.VisitDate.DayOfWeek;
                    var arrivalMinutes = (int)point.StartTime.TotalMinutes;

                    var todayPeriod = placeDetails.OpeningPeriods
                        .FirstOrDefault(p => p.Open.Day == arrivalDay);

                    if (todayPeriod != null && todayPeriod.Close != null)
                    {
                        var closeMinutes = todayPeriod.Close.Hours * 60 + todayPeriod.Close.Minutes;
                        point.WillBeClosed = arrivalMinutes >= closeMinutes;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Opening hours check error: {ex.Message}");
        }
    }

    // === Transit ikon ===
    private string GetTransitIcon(string vehicleType)
    {
        return vehicleType switch
        {
            "BUS" => "bus-front",
            "SUBWAY" => "train-subway",
            "TRAM" => "train-lightrail-front",
            "RAIL" => "train-front",
            "FERRY" => "ferry",
            _ => "bus-front"
        };
    }



    // === Szín generálás pontokhoz ===
    private string GetPointColor(int order)
    {
        // HSL színrendszer: Hue (0-360), Saturation, Lightness
        // Minden pont különböző árnyalatot kap (egyenletes elosztás a színkörön)
        int hue = (order * 360 / Math.Max(routePoints.Count, 1)) % 360;

        // Telítettség: 70% (élénk színek)
        // Világosság: 45% (sem túl sötét, sem túl világos)
        return $"hsl({hue}, 70%, 45%)";
    }

