@page "/ut-tervezes"
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Út tervezése — TeUtad</PageTitle>

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet"/>
    

    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyBL9wuHLIfIK1LLTkqPA6sW4ltfXl2rbfo&libraries=places&callback=Function.prototype" async defer></script>
    <script src="/js/googleMaps.js"></script>
</head>



<div class="container py-5">
    @* Lépésjelző *@
    <div class="step-indicator">
        <div class="step-item @(currentStep >= 1 ? "completed" : "") @(currentStep == 1 ? "active" : "")">
            <div class="step-circle">
                @if (currentStep > 1) { <i class="bi bi-check-lg"></i> } else { <span>1</span> }
            </div>
            <div class="small fw-semibold">Útvonal</div>
        </div>
        <div class="step-item @(currentStep >= 2 ? "completed" : "") @(currentStep == 2 ? "active" : "")">
            <div class="step-circle">
                @if (currentStep > 2) { <i class="bi bi-check-lg"></i> } else { <span>2</span> }
            </div>
            <div class="small fw-semibold">Repjegy</div>
        </div>
        <div class="step-item @(currentStep >= 3 ? "completed" : "") @(currentStep == 3 ? "active" : "")">
            <div class="step-circle">
                @if (currentStep > 3) { <i class="bi bi-check-lg"></i> } else { <span>3</span> }
            </div>
            <div class="small fw-semibold">Szállás</div>
        </div>
        <div class="step-item @(currentStep == 4 ? "active" : "")">
            <div class="step-circle">4</div>
            <div class="small fw-semibold">Autóbérlés</div>
        </div>
    </div>

    @* Fő tartalom kártya *@
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-md-5">
            
            @if (currentStep == 1)
            {
                @* 1. LÉPÉS: Útvonaltervezés *@
                <h2 class="fw-bold mb-4">
                    <i class="bi bi-map me-2 text-primary"></i>
                    Útvonal tervezése
                </h2>
                
                <div class="row">
                    <div class="col-lg-4 mb-4 mb-lg-0">
                        <h5 class="fw-semibold mb-3">Útvonal pontok</h5>
                        
                        @* Autocomplete keresés *@
                        <div class="mb-3">
                            <label class="form-label small text-muted">
                                <i class="bi bi-search me-1"></i>
                                Új helyszín keresése
                            </label>
                            <input type="text" 
                                   id="autocomplete-input" 
                                   class="form-control" 
                                   placeholder="Pl. Halászbástya, Parlament..." />
                            <small class="text-muted">Kezdj el gépelni és válassz a listából!</small>
                        </div>

                        <hr class="my-3" />
                        
                        @* Útvonalpontok listája *@
                        @foreach (var point in routePoints)
                        {
                            <div class="route-point">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="flex-grow-1">
                                        <div class="small text-muted">@point.Order. állomás</div>
                                        <div class="fw-bold">@point.AttractionName</div>
                                        <div class="small text-muted">
                                            <i class="bi bi-geo-alt me-1"></i>@point.Address
                                        </div>
                                        <span class="badge bg-primary-subtle text-primary mt-1">@point.Category</span>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="@(() => RemoveRoutePoint(point.Id))">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                                <div class="small">
                                    <i class="bi bi-calendar me-1"></i>
                                    @point.VisitDate.ToString("yyyy. MM. dd.")
                                    <i class="bi bi-clock ms-2 me-1"></i>
                                    @point.StartTime.ToString(@"hh\:mm") - @point.EndTime.ToString(@"hh\:mm")
                                </div>
                            </div>
                        }

                        @* Statisztikák *@
                        <div class="mt-4 p-3 bg-light rounded">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Helyszínek száma:</span>
                                <span class="fw-bold">@routePoints.Count db</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Teljes időtartam:</span>
                                <span class="fw-bold">@totalHours óra</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Látogatási napok:</span>
                                <span class="fw-bold">@totalDays nap</span>
                            </div>
                        </div>
                    </div>

                    @* Google Maps térkép *@
                    <div class="col-lg-8">
                        <div id="map"></div>
                        <p class="small text-muted mt-2 text-center">
                            <i class="bi bi-info-circle me-1"></i>
                            Kattints a markerekre a részletekért
                        </p>
                    </div>
                </div>
            }

            @if (currentStep == 2)
            {
                @* 2. LÉPÉS: Repjegy kiválasztása *@
                <h2 class="fw-bold mb-4">
                    <i class="bi bi-airplane me-2 text-primary"></i>
                    Repjegy kiválasztása
                </h2>

                <div class="row g-4">
                    @foreach (var flight in availableFlights)
                    {
                        <div class="col-md-6">
                            <div class="card flight-card border rounded-4 h-100 position-relative @(selectedFlightId == flight.Id ? "selected" : "")"
                                 @onclick="@(() => SelectFlight(flight.Id))">
                                <div class="price-badge">@flight.Price Ft</div>
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="bg-primary bg-opacity-10 rounded-circle p-2 me-3">
                                            <i class="bi bi-airplane-fill text-primary fs-4"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold">@flight.Airline</div>
                                            <div class="small text-muted">@flight.FlightNumber</div>
                                        </div>
                                    </div>

                                    <div class="row align-items-center mb-3">
                                        <div class="col">
                                            <div class="fw-bold fs-5">@flight.DepartureTime</div>
                                            <div class="text-muted">@flight.DepartureCity</div>
                                        </div>
                                        <div class="col-auto">
                                            <div class="text-center">
                                                <i class="bi bi-arrow-right text-primary"></i>
                                                <div class="small text-muted">@flight.Duration</div>
                                            </div>
                                        </div>
                                        <div class="col text-end">
                                            <div class="fw-bold fs-5">@flight.ArrivalTime</div>
                                            <div class="text-muted">@flight.ArrivalCity</div>
                                        </div>
                                    </div>

                                    <div class="d-flex gap-2">
                                        <span class="badge bg-success-subtle text-success">@flight.Class</span>
                                        @if (flight.DirectFlight)
                                        {
                                            <span class="badge bg-primary-subtle text-primary">Direkt járat</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning-subtle text-warning">@flight.Stops átszállás</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @* Kihagy opció *@
                    <div class="col-12">
                        <div class="skip-option" @onclick="@(() => selectedFlightId = null)">
                            <i class="bi bi-x-circle display-6 text-muted mb-2"></i>
                            <p class="mb-0 fw-semibold">Nincs szükségem repjegyre</p>
                            <small class="text-muted">Saját járatot foglalok vagy más közlekedési eszközt használok</small>
                        </div>
                    </div>
                </div>
            }

            @if (currentStep == 3)
            {
                @* 3. LÉPÉS: Szállás kiválasztása *@
                <h2 class="fw-bold mb-4">
                    <i class="bi bi-building me-2 text-primary"></i>
                    Szállás kiválasztása
                </h2>

                <div class="row g-4">
                    @foreach (var hotel in availableHotels)
                    {
                        <div class="col-md-6">
                            <div class="card hotel-card border rounded-4 h-100 position-relative @(selectedHotelId == hotel.Id ? "selected" : "")"
                                 @onclick="@(() => SelectHotel(hotel.Id))">
                                <div class="price-badge">@hotel.PricePerNight Ft / éj</div>
                                <div class="card-body p-4">
                                    <div class="mb-3">
                                        <h5 class="fw-bold mb-1">@hotel.Name</h5>
                                        <div class="text-muted small">
                                            <i class="bi bi-geo-alt-fill me-1"></i>@hotel.Location
                                        </div>
                                        <div class="mt-2">
                                            @for (int i = 0; i < hotel.Stars; i++)
                                            {
                                                <i class="bi bi-star-fill text-warning"></i>
                                            }
                                            <span class="ms-2 small text-muted">(@hotel.Rating / 10)</span>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var amenity in hotel.Amenities)
                                            {
                                                <span class="badge bg-secondary-subtle text-secondary">
                                                    <i class="bi bi-check-circle me-1"></i>@amenity
                                                </span>
                                            }
                                        </div>
                                    </div>

                                    <div class="small text-muted">
                                        <i class="bi bi-people me-1"></i>
                                        Max @hotel.MaxGuests fő · @hotel.RoomType
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @* Kihagy opció *@
                    <div class="col-12">
                        <div class="skip-option" @onclick="@(() => selectedHotelId = null)">
                            <i class="bi bi-x-circle display-6 text-muted mb-2"></i>
                            <p class="mb-0 fw-semibold">Nincs szükségem szállásra</p>
                            <small class="text-muted">Barátaimnál / családnál szállok meg vagy saját magam foglalom</small>
                        </div>
                    </div>
                </div>
            }

            @if (currentStep == 4)
            {
                @* 4. LÉPÉS: Autóbérlés *@
                <h2 class="fw-bold mb-4">
                    <i class="bi bi-car-front me-2 text-primary"></i>
                    Autóbérlés
                </h2>

                <div class="row g-4">
                    @foreach (var car in availableCars)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card car-card border rounded-4 h-100 position-relative @(selectedCarId == car.Id ? "selected" : "")"
                                 @onclick="@(() => SelectCar(car.Id))">
                                <div class="price-badge">@car.PricePerDay Ft / nap</div>
                                <div class="card-body p-4">
                                    <div class="text-center mb-3">
                                        <div class="display-1">@car.Icon</div>
                                        <h5 class="fw-bold mb-1">@car.Model</h5>
                                        <div class="text-muted small">@car.Brand</div>
                                    </div>

                                    <div class="d-flex justify-content-around text-center mb-3">
                                        <div>
                                            <i class="bi bi-people text-muted"></i>
                                            <div class="small">@car.Seats fő</div>
                                        </div>
                                        <div>
                                            <i class="bi bi-briefcase text-muted"></i>
                                            <div class="small">@car.Luggage db</div>
                                        </div>
                                        <div>
                                            <i class="bi bi-gear text-muted"></i>
                                            <div class="small">@car.Transmission</div>
                                        </div>
                                    </div>

                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var feature in car.Features)
                                        {
                                            <span class="badge bg-info-subtle text-info small">@feature</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @* Kihagy opció *@
                    <div class="col-12">
                        <div class="skip-option" @onclick="@(() => selectedCarId = null)">
                            <i class="bi bi-x-circle display-6 text-muted mb-2"></i>
                            <p class="mb-0 fw-semibold">Nincs szükségem autóbérlésre</p>
                            <small class="text-muted">Tömegközlekedést használok vagy saját autóval megyek</small>
                        </div>
                    </div>
                </div>
            }

            @* Navigációs gombok *@
            <div class="d-flex justify-content-between mt-5 pt-4 border-top">
                @if (currentStep > 1)
                {
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" @onclick="PreviousStep">
                        <i class="bi bi-arrow-left me-2"></i>
                        Vissza
                    </button>
                }
                else
                {
                    <div></div>
                }

                @if (currentStep < 4)
                {
                    <button type="button" class="btn btn-primary rounded-pill px-4" @onclick="NextStep">
                        Tovább
                        <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                }
                else
                {
                    <button type="button" class="btn btn-success rounded-pill px-4" @onclick="FinishBooking">
                        <i class="bi bi-check-circle me-2"></i>
                        Foglalás véglegesítése
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

@code {
    // === Állapot változók ===
    private int currentStep = 1;
    private int? selectedFlightId = null;
    private int? selectedHotelId = null;
    private int? selectedCarId = null;
    private int totalHours = 0;
    private int totalDays = 2;
    
    // DotNetObjectReference az autocomplete callback-hez
    private DotNetObjectReference<UtTervezes>? dotNetHelper;

    // === Útvonalpont osztály ===
    private class RoutePoint
    {
        public int Id { get; set; }
        public int Order { get; set; }
        public string AttractionName { get; set; }
        public string Address { get; set; }
        public DateTime VisitDate { get; set; }
        public TimeSpan StartTime { get; set; }
        public TimeSpan EndTime { get; set; }
        public string Category { get; set; }
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public string PlaceId { get; set; } = "";
    }

    // === Kezdő útvonalpontok ===
    private List<RoutePoint> routePoints = new List<RoutePoint>
    {
        new RoutePoint 
        { 
            Id = 1, Order = 1, 
            AttractionName = "Halászbástya", 
            Address = "Budapest, Szentháromság tér",
            VisitDate = DateTime.Now.AddDays(7), 
            StartTime = new TimeSpan(9, 0, 0), 
            EndTime = new TimeSpan(11, 0, 0),
            Category = "Látnivaló",
            Latitude = 47.5023, 
            Longitude = 19.0348
        },
        new RoutePoint 
        { 
            Id = 2, Order = 2, 
            AttractionName = "Parlament",
            Address = "Budapest, Kossuth Lajos tér 1-3",
            VisitDate = DateTime.Now.AddDays(7),
            StartTime = new TimeSpan(11, 30, 0),
            EndTime = new TimeSpan(13, 0, 0),
            Category = "Történelem",
            Latitude = 47.5075,
            Longitude = 19.0458
        },
        new RoutePoint 
        { 
            Id = 3, Order = 3,
            AttractionName = "Széchenyi Gyógyfürdő",
            Address = "Budapest, Állatkerti krt. 9-11",
            VisitDate = DateTime.Now.AddDays(7),
            StartTime = new TimeSpan(14, 0, 0),
            EndTime = new TimeSpan(17, 0, 0),
            Category = "Wellness",
            Latitude = 47.5197,
            Longitude = 19.0816
        }
    };

    // === Repjegy osztály ===
    private class Flight
    {
        public int Id { get; set; }
        public string Airline { get; set; }
        public string FlightNumber { get; set; }
        public string DepartureCity { get; set; }
        public string ArrivalCity { get; set; }
        public string DepartureTime { get; set; }
        public string ArrivalTime { get; set; }
        public string Duration { get; set; }
        public int Price { get; set; }
        public string Class { get; set; }
        public bool DirectFlight { get; set; }
        public int Stops { get; set; }
    }

    // === Elérhető repjegyek ===
    private List<Flight> availableFlights = new List<Flight>
    {
        new Flight { Id = 1, Airline = "Wizz Air", FlightNumber = "W6 2301", DepartureCity = "Bécs", ArrivalCity = "Budapest", DepartureTime = "08:00", ArrivalTime = "09:30", Duration = "1ó 30p", Price = 18000, Class = "Economy", DirectFlight = true, Stops = 0 },
        new Flight { Id = 2, Airline = "Ryanair", FlightNumber = "FR 8247", DepartureCity = "Pozsony", ArrivalCity = "Budapest", DepartureTime = "12:15", ArrivalTime = "13:20", Duration = "1ó 05p", Price = 12500, Class = "Economy", DirectFlight = true, Stops = 0 },
        new Flight { Id = 3, Airline = "Lufthansa", FlightNumber = "LH 1234", DepartureCity = "München", ArrivalCity = "Budapest", DepartureTime = "10:00", ArrivalTime = "11:45", Duration = "1ó 45p", Price = 32000, Class = "Economy Plus", DirectFlight = true, Stops = 0 },
        new Flight { Id = 4, Airline = "Austrian Airlines", FlightNumber = "OS 714", DepartureCity = "Bécs", ArrivalCity = "Budapest", DepartureTime = "18:20", ArrivalTime = "19:50", Duration = "1ó 30p", Price = 28000, Class = "Business", DirectFlight = true, Stops = 0 }
    };

    // === Hotel osztály ===
    private class Hotel
    {
        public int Id { get; set; }
        public string Name { get; set; }
        public string Location { get; set; }
        public int Stars { get; set; }
        public double Rating { get; set; }
        public int PricePerNight { get; set; }
        public List<string> Amenities { get; set; }
        public int MaxGuests { get; set; }
        public string RoomType { get; set; }
    }

    // === Elérhető szállások ===
    private List<Hotel> availableHotels = new List<Hotel>
    {
        new Hotel { Id = 1, Name = "Four Seasons Hotel Gresham Palace", Location = "Budapest, Széchenyi István tér 5-6", Stars = 5, Rating = 9.4, PricePerNight = 85000, Amenities = new List<string> { "WiFi", "Reggeli", "Medence", "Spa", "Duna-kilátás" }, MaxGuests = 2, RoomType = "Deluxe szoba" },
        new Hotel { Id = 2, Name = "Ibis Budapest City", Location = "Budapest, Rákóczi út", Stars = 3, Rating = 8.2, PricePerNight = 22000, Amenities = new List<string> { "WiFi", "Reggeli", "Parkoló" }, MaxGuests = 3, RoomType = "Standard szoba" },
        new Hotel { Id = 3, Name = "Danubius Hotel Margitsziget", Location = "Budapest, Margitsziget", Stars = 4, Rating = 8.9, PricePerNight = 38000, Amenities = new List<string> { "WiFi", "Reggeli", "Wellness", "Термál fürdő" }, MaxGuests = 2, RoomType = "Superior szoba" },
        new Hotel { Id = 4, Name = "Maverick Hostel & Ensuites", Location = "Budapest, Kazinczy utca", Stars = 2, Rating = 8.6, PricePerNight = 8500, Amenities = new List<string> { "WiFi", "Közös konyha", "Bár" }, MaxGuests = 4, RoomType = "Többágyas szoba" }
    };

    // === Autó osztály ===
    private class Car
    {
        public int Id { get; set; }
        public string Brand { get; set; }
        public string Model { get; set; }
        public string Icon { get; set; }
        public int Seats { get; set; }
        public int Luggage { get; set; }
        public string Transmission { get; set; }
        public int PricePerDay { get; set; }
        public List<string> Features { get; set; }
    }

    // === Elérhető autók ===
    private List<Car> availableCars = new List<Car>
    {
        new Car { Id = 1, Brand = "Volkswagen", Model = "Golf", Icon = "🚗", Seats = 5, Luggage = 2, Transmission = "Automata", PricePerDay = 12000, Features = new List<string> { "Klíma", "GPS", "Bluetooth" } },
        new Car { Id = 2, Brand = "BMW", Model = "3-as sorozat", Icon = "🚙", Seats = 5, Luggage = 3, Transmission = "Automata", PricePerDay = 28000, Features = new List<string> { "Klíma", "GPS", "Bőrülés", "Tempomat" } },
        new Car { Id = 3, Brand = "Ford", Model = "Fiesta", Icon = "🚗", Seats = 5, Luggage = 1, Transmission = "Manuális", PricePerDay = 8500, Features = new List<string> { "Klíma", "Bluetooth" } },
        new Car { Id = 4, Brand = "Mercedes", Model = "E-osztály", Icon = "🚘", Seats = 5, Luggage = 3, Transmission = "Automata", PricePerDay = 42000, Features = new List<string> { "Klíma", "GPS", "Bőrülés", "Tempomat", "Parkolóradar" } },
        new Car { Id = 5, Brand = "Opel", Model = "Corsa", Icon = "🚗", Seats = 5, Luggage = 2, Transmission = "Manuális", PricePerDay = 7000, Features = new List<string> { "Klíma" } },
        new Car { Id = 6, Brand = "Audi", Model = "A6", Icon = "🚙", Seats = 5, Luggage = 3, Transmission = "Automata", PricePerDay = 35000, Features = new List<string> { "Klíma", "GPS", "Bőrülés", "Ülésfűtés" } }
    };

    // === Inicializálás oldal betöltésekor ===
    protected override void OnInitialized()
    {
        RecalculateTotals();
    }

    // === Térkép és autocomplete inicializálása ===
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Várunk, hogy a Google Maps betöltődjön
                await Task.Delay(1500);
                
                // DotNetObjectReference létrehozása
                dotNetHelper = DotNetObjectReference.Create(this);
                
                // Térkép inicializálása
                await InitializeMap();
                
                // Autocomplete inicializálása
                await JSRuntime.InvokeVoidAsync("initAutocomplete", "autocomplete-input", dotNetHelper);
                
                Console.WriteLine("✅ Google Maps és Autocomplete inicializálva!");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"❌ Map initialization error: {ex.Message}");
            }
        }
    }

    // === Térkép inicializálása a jelenlegi pontokkal ===
    private async Task InitializeMap()
    {
        try
        {
            // Objektum tömb létrehozása a JavaScript számára
            var routeData = routePoints.Select(p => new
            {
                attractionName = p.AttractionName,
                address = p.Address,
                latitude = p.Latitude,
                longitude = p.Longitude,
                startTime = p.StartTime.ToString(@"hh\:mm"),
                endTime = p.EndTime.ToString(@"hh\:mm")
            }).ToArray();

            await JSRuntime.InvokeVoidAsync("initMap", (object)routeData, "map");
            Console.WriteLine($"✅ Térkép inicializálva {routePoints.Count} ponttal");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ InitializeMap error: {ex.Message}");
        }
    }

    // === Térkép frissítése ===
    private async Task UpdateMap()
    {
        try
        {
            // FONTOS: Objektum tömb létrehozása, NEM közvetlenül a routePoints!
            var routeData = routePoints.Select(p => new
            {
                attractionName = p.AttractionName,
                address = p.Address,
                latitude = p.Latitude,
                longitude = p.Longitude,
                startTime = p.StartTime.ToString(@"hh\:mm"),
                endTime = p.EndTime.ToString(@"hh\:mm")
            }).ToArray();

            // Cast object-re, hogy biztosan tömbként menjen át
            await JSRuntime.InvokeVoidAsync("updateMap", (object)routeData);
            Console.WriteLine($"✅ Térkép frissítve {routePoints.Count} ponttal");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ UpdateMap error: {ex.Message}");
        }
    }

    // === AUTOCOMPLETE CALLBACK - JavaScript hívja meg ===
    [JSInvokable]
    public async Task OnPlaceSelected(PlaceData placeData)
    {
        try
        {
            // Utolsó pont lekérése
            var lastPoint = routePoints.LastOrDefault();
            var newVisitDate = lastPoint?.VisitDate ?? DateTime.Now.AddDays(7);
            var newStartTime = lastPoint?.EndTime.Add(TimeSpan.FromHours(1)) ?? new TimeSpan(9, 0, 0);
            
            // Ha már késő van, következő napra tesszük
            if (newStartTime.TotalHours >= 22)
            {
                newVisitDate = newVisitDate.AddDays(1);
                newStartTime = new TimeSpan(9, 0, 0);
            }
            
            // Új pont hozzáadása
            routePoints.Add(new RoutePoint
            {
                Id = routePoints.Any() ? routePoints.Max(p => p.Id) + 1 : 1,
                Order = routePoints.Count + 1,
                AttractionName = placeData.Name,
                Address = placeData.Address,
                VisitDate = newVisitDate,
                StartTime = newStartTime,
                EndTime = newStartTime.Add(TimeSpan.FromHours(2)),
                Category = "Látnivaló",
                Latitude = placeData.Latitude,
                Longitude = placeData.Longitude,
                PlaceId = placeData.PlaceId
            });
            
            RecalculateTotals();
            await UpdateMap();
            
            // Input mező ürítése
            await JSRuntime.InvokeVoidAsync("eval", 
                "document.getElementById('autocomplete-input').value = ''");
            
            StateHasChanged();
            
            Console.WriteLine($"✅ Új hely hozzáadva: {placeData.Name}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ OnPlaceSelected error: {ex.Message}");
        }
    }

    // === Útvonalpont törlése ===
    private async Task RemoveRoutePoint(int id)
    {
        try
        {
            var point = routePoints.FirstOrDefault(p => p.Id == id);
            if (point != null && routePoints.Count > 1)
            {
                routePoints.Remove(point);
                
                // Sorrend újraszámozása
                for (int i = 0; i < routePoints.Count; i++)
                {
                    routePoints[i].Order = i + 1;
                }
                
                RecalculateTotals();
                await UpdateMap();
                StateHasChanged();
                
                Console.WriteLine($"✅ Pont törölve: {point.AttractionName}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ RemoveRoutePoint error: {ex.Message}");
        }
    }

    // === Statisztikák újraszámolása ===
    private void RecalculateTotals()
    {
        if (routePoints.Any())
        {
            var firstDate = routePoints.Min(p => p.VisitDate);
            var lastDate = routePoints.Max(p => p.VisitDate);
            totalDays = (lastDate - firstDate).Days + 1;
            
            double totalMinutes = 0;
            foreach (var point in routePoints)
            {
                totalMinutes += (point.EndTime - point.StartTime).TotalMinutes;
            }
            totalHours = (int)(totalMinutes / 60);
        }
        else
        {
            totalDays = 0;
            totalHours = 0;
        }
    }

    // === Léptetés előre ===
    private void NextStep()
    {
        if (currentStep < 4)
        {
            currentStep++;
            StateHasChanged();
        }
    }

    // === Léptetés hátra ===
    private void PreviousStep()
    {
        if (currentStep > 1)
        {
            currentStep--;
            StateHasChanged();
        }
    }

    // === Repjegy kiválasztása ===
    private void SelectFlight(int flightId)
    {
        selectedFlightId = selectedFlightId == flightId ? null : flightId;
        StateHasChanged();
    }

    // === Hotel kiválasztása ===
    private void SelectHotel(int hotelId)
    {
        selectedHotelId = selectedHotelId == hotelId ? null : hotelId;
        StateHasChanged();
    }

    // === Autó kiválasztása ===
    private void SelectCar(int carId)
    {
        selectedCarId = selectedCarId == carId ? null : carId;
        StateHasChanged();
    }

    // === Foglalás véglegesítése ===
    private void FinishBooking()
    {
        var summary = $"📋 Foglalás összesítő:\n";
        summary += $"  🗺️ Útvonal: {routePoints.Count} helyszín, {totalDays} nap, {totalHours} óra\n";
        summary += $"  ✈️ Repjegy: {(selectedFlightId.HasValue ? "Kiválasztva (#" + selectedFlightId + ")" : "Nincs")}\n";
        summary += $"  🏨 Szállás: {(selectedHotelId.HasValue ? "Kiválasztva (#" + selectedHotelId + ")" : "Nincs")}\n";
        summary += $"  🚗 Autó: {(selectedCarId.HasValue ? "Kiválasztva (#" + selectedCarId + ")" : "Nincs")}";
        
        Console.WriteLine(summary);
        
        // Itt menthetnéd az adatokat az API-ba vagy adatbázisba
        // await HttpClient.PostAsJsonAsync("/api/bookings", bookingData);
    }

