@page "/profil"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@using TeUtad.LIB.Modul
@using System.Security.Cryptography
@using System.Text
@using TeUtad.MODEL
@using TeUtad.SERVICE
@rendermode @(new InteractiveServerRenderMode())
@inject FelhasznaloSzerviz FelhasznaloSzerv
@inject UtazasSzerviz UtazasSzerv
@inject FelhasznaloAuthState AutheriState
@inject NavigationManager nav

<PageTitle>Profilom — TeUtad</PageTitle>

<head>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
	<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
</head>


<!-- Profile Header -->
<div class="profile-header text-white">
	<div class="container">
		<div class="row align-items-center">
			<div class="col-auto">
				<div class="profile-avatar">
					<span>@GetInitials(felhasznalo.FelhasznaloNev)</span>
				</div>
			</div>
			<div class="col">
				<h2 class="fw-bold mb-1">@felhasznalo.FelhasznaloNev</h2>
				<p class="mb-2 opacity-75">@felhasznalo.Email</p>
			</div>
			<div class="col-auto">
				<button type="button" class="btn btn-light rounded-pill" @onclick="EditProfile">
					<i class="bi bi-pencil me-2"></i>
					Profil szerkesztése
				</button>
			</div>
		</div>
	</div>
</div>

<div class="container pb-5">
	<div class="row g-4">
		<!-- Left Column - Stats -->
		<div class="col-lg-4">
			<div class="card border-0 shadow-sm rounded-4 mb-4">
				<div class="card-body p-4">
					<h5 class="fw-bold mb-4">Statisztikák</h5>

					<div class="row g-3">
						<div>
							<div class="stat-card">
								<div class="stat-value">@utakSzama</div>
								<div class="small text-muted">Utazás</div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Quick Actions -->
			<div class="card border-0 shadow-sm rounded-4">
				<div class="card-body p-4">
					<h5 class="fw-bold mb-3">Gyors műveletek</h5>
					<div class="d-grid gap-2">
						<a href="/ut-tervezes" class="btn btn-primary rounded-pill">
							<i class="bi bi-plus-circle me-2"></i>
							Új út tervezése
						</a>
						<a href="/korabbi-utak" class="btn btn-outline-primary rounded-pill">
							<i class="bi bi-clock-history me-2"></i>
							Korábbi utak
						</a>
					</div>
				</div>
			</div>
		</div>

		<!-- Right Column - Settings & Info -->
		<div class="col-lg-8">
			<!-- Personal Information -->
			<div class="card border-0 shadow-sm rounded-4 mb-4">
				<div class="card-body p-4">
					<h5 class="fw-bold mb-4">Személyes adatok</h5>

					<div class="row g-3">
						<div class="col-md-6">
							<label class="form-label small text-muted">Teljes név</label>
							<input type="text" class="form-control" @bind="felhasznalo.FelhasznaloNev" disabled="@(!isEditing)" />
						</div>
						<div class="col-md-6">
							<label class="form-label small text-muted">E-mail cím</label>
							<input type="email" class="form-control" @bind="felhasznalo.Email" disabled="@(!isEditing)" />
						</div>
					</div>

					@if (isEditing)
					{
						<div class="d-flex gap-2 mt-4">
							<button type="button" class="btn btn-primary rounded-pill" @onclick="SaveProfile">
								<i class="bi bi-check-circle me-2"></i>
								Mentés
							</button>
							<button type="button" class="btn btn-outline-secondary rounded-pill" @onclick="CancelEdit">
								Mégse
							</button>
						</div>
					}
				</div>
			</div>

			<!-- Security -->
			<div class="card border-0 shadow-sm rounded-4">
				<div class="card-body p-4">
					<h5 class="fw-bold mb-4">Biztonság</h5>

					<div class="setting-item">
						<div class="d-flex justify-content-between align-items-center">
							<div>
								<div class="fw-semibold">Jelszó megváltoztatása</div>
							</div>
							<button type="button" class="btn btn-outline-primary btn-sm rounded-pill" @onclick="ChangePassword">
								Módosítás
							</button>
						</div>
					</div>

					<div class="setting-item">
						<div class="d-flex justify-content-between align-items-center">
							<div>
								<div class="fw-semibold">Kijelentkezés és FiókTörlése</div>
							</div>
							<button type="button" class="btn btn-outline-danger btn-sm rounded-pill" @onclick="KijelentkezesEsTorlesAtiranyit">
								Kijelentkezés
							</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
@if (jelszoValt)
{
	<div class="modal fade show" tabindex="-1" style="display: block; background-color: rgba(0,0,0,0.5);" @onclick="Bezar">
		<div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title">Jelszó modosítás</h5>
					<button type="button" class="btn-close" @onclick="Bezar"></button>
				</div>
				<div class="modal-body">
					<input @bind="RegiJelszo"
					class="form-control mb-2"
					placeholder="Régi jelszava ide"
					autofocus />
					<input @bind="Ujelszo"
					class="form-control"
					placeholder="Új jelszava ide"
					/>
				</div>
				<p>@error</p>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" @onclick="Bezar">Bezar</button>
					<button type="button" class="btn btn-primary" @onclick="JelszoMod">Módositás</button>
				</div>
			</div>
		</div>
	</div>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

@code {
	public List<FelhasznaloAdat> Felhasznalok;
	public FelhasznaloAdat felhasznalo { get; set; } = new();
	public int utakSzama = 0;
	private bool isEditing = false;
	private bool jelszoValt = false;
	private string Ujelszo = "";
	private string RegiJelszo = "";
	private string error = "";

	protected override async Task OnInitializedAsync()
	{
		var Utazasok = await UtazasSzerv.GetAllUtazas();
		var authState = await AutheriState.GetAuthenticationStateAsync();
		var felhasznaloId = Convert.ToInt32(authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value);
		Felhasznalok = await FelhasznaloSzerv.GetAllFelhasznalo();
		felhasznalo = Felhasznalok.FirstOrDefault(x => x.id == felhasznaloId);
		utakSzama = Utazasok.Count(x => x.FelhasznaloId == felhasznalo.id);
	}
	private string GetInitials(string fullName)
	{
		if (string.IsNullOrWhiteSpace(fullName))
			return "?";

		var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
		if (parts.Length >= 2)
			return $"{parts[0][0]}{parts[1][0]}".ToUpper();

		return fullName[0].ToString().ToUpper();
	}

	private void EditProfile()
	{
		isEditing = true;
		StateHasChanged();
	}

	private async void SaveProfile()
	{
		await FelhasznaloSzerv.UpdateFelhasznalo(felhasznalo);
		var mostaniAuthState = await AutheriState.GetAuthenticationStateAsync();
		var mostaniFelhasznaloPrincable = mostaniAuthState.User;
		var newIdentity = new ClaimsIdentity(mostaniFelhasznaloPrincable.Identity?.AuthenticationType);
		foreach (var claim in mostaniFelhasznaloPrincable.Claims)
		{
			if (claim.Type != ClaimTypes.Name)
				newIdentity.AddClaim(claim);
		}
		newIdentity.AddClaim(new Claim(ClaimTypes.Name, felhasznalo.FelhasznaloNev));

		var newUser = new ClaimsPrincipal(newIdentity);

		AutheriState.UpdateAuthenticationState(newUser);

		isEditing = false;
		StateHasChanged();
	}

	private void CancelEdit()
	{
		isEditing = false;
		// Itt visszaállíthatnád az eredeti adatokat
	}

	private async void ChangePassword()
	{
		jelszoValt = true;
	}
	private void KijelentkezesEsTorlesAtiranyit()
	{
		nav.NavigateTo("/KijelentTorles");
	}
	private void Bezar()
	{
		jelszoValt = false;
	}
	private void JelszoMod()
	{
		var Sha = new SHA256Managed();
		RegiJelszo = Convert.ToBase64String(Sha.ComputeHash(Encoding.UTF8.GetBytes(RegiJelszo)));
		if (RegiJelszo == felhasznalo.JelszoHash)
		{
			felhasznalo.JelszoHash = Convert.ToBase64String(Sha.ComputeHash(Encoding.UTF8.GetBytes(Ujelszo)));
			FelhasznaloSzerv.UpdateFelhasznalo(felhasznalo);
			RegiJelszo = "";
			Ujelszo = "";
			Bezar();
			StateHasChanged();
		}
		else
		{
			RegiJelszo = "";
			Ujelszo = "";
			error = "A régi jelszavad nem egyezik meg!";
		}
	}
}